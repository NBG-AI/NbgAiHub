---
// site/src/components/SocialIconsOverride.astro
//
// Replaces Starlight 0.39's `SocialIcons` slot (per investigation R6 — we
// override the slot, NOT the whole Header) to host the sign-in affordance.
//
// Scope after the 2026-05-19 unified-header refactor: this file is used
// ONLY on non-splash (content-detail) pages, where Starlight's default
// Header renders. On splash pages, the SplashAwareHeader override takes
// over and renders AuthControls + SignInModal directly inside the unified
// nbg-topnav — SocialIcons is never rendered there.
//
// This component is intentionally a thin wrapper now: AuthControls handles
// the Sign in XOR chip render + JS, and SignInModal mounts the dialog. The
// only reason this file still exists is that Starlight's component override
// map needs a single .astro file at the `SocialIcons` slot.
//
// Related: project-design.md §S.13.6.1.
import AuthControls from './AuthControls.astro';
import SignInModal from './SignInModal.astro';

const { entry } = Astro.locals.starlightRoute;
const isSplash = entry.data.template === 'splash';
---

{!isSplash && (
  <>
    <AuthControls />
    <SignInModal />
  </>
)}
