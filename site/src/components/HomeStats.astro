---
/**
 * HomeStats.astro — Build-time content counts strip for the homepage.
 *
 * Reads the four content collections (skills, tips, glossary, news) at SSG
 * time and renders an editorial counts panel with display-sized, tabular
 * figures. Sits in the homepage hero end-slot.
 *
 * Layout (2026-05-19 final): CSS Grid `grid-template-columns: 1fr 1fr`
 * with separator <div role="separator"> elements interspersed in the DOM.
 * Each separator spans both columns (`grid-column: 1 / -1`) drawing a
 * single continuous hairline above its row. Row-major flow is guaranteed
 * by CSS Grid's default auto-placement; there is no flex-wrap subpixel
 * weirdness and no row containers to introduce indirection.
 *
 * DOM order:
 *   separator
 *   skills cell | tips cell
 *   separator
 *   glossary cell | news cell
 *
 * Renders visually as a 2×2 grid with one full-width hairline above each
 * row. Earlier attempts (per-cell `border-top` with `column-gap: 0`, or
 * `::before` pseudo overlap, or flex row wrappers) all hit different
 * rendering bugs across attempts. This is the bulletproof shape.
 *
 * Related: project-design.md §S.13.10.1 + plan-004-ui-redesign.md P4.E.
 * Portability: ZERO Starlight imports — uses primitives + design tokens only.
 */
import { getCollection } from 'astro:content';
import Eyebrow from './primitives/Eyebrow.astro';

const [skills, tips, glossary, news] = await Promise.all([
  getCollection('skills'),
  getCollection('tips'),
  getCollection('glossary'),
  getCollection('news'),
]);

type Stat = { label: string; value: number };

const stats: ReadonlyArray<Stat> = [
  { label: 'skills',   value: skills.length   },
  { label: 'tips',     value: tips.length     },
  { label: 'glossary', value: glossary.length },
  { label: 'news',     value: news.length     },
];
---
<div class="home-stats" data-tabular>
  <Eyebrow tone="accent">By the numbers</Eyebrow>
  <div class="home-stats__panel">
    <div class="home-stats__divider" role="separator" aria-hidden="true"></div>

    <div class="home-stats__cell">
      <span class="home-stats__value">{stats[0]!.value}</span>
      <span class="home-stats__label">{stats[0]!.label}</span>
    </div>
    <div class="home-stats__cell">
      <span class="home-stats__value">{stats[1]!.value}</span>
      <span class="home-stats__label">{stats[1]!.label}</span>
    </div>

    <div class="home-stats__divider" role="separator" aria-hidden="true"></div>

    <div class="home-stats__cell">
      <span class="home-stats__value">{stats[2]!.value}</span>
      <span class="home-stats__label">{stats[2]!.label}</span>
    </div>
    <div class="home-stats__cell">
      <span class="home-stats__value">{stats[3]!.value}</span>
      <span class="home-stats__label">{stats[3]!.label}</span>
    </div>
  </div>
</div>

<style>
  @layer nbg.components {
    .home-stats {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-6);
      padding-block: var(--nbg-sp-4);
    }

    /* CSS Grid: 2 columns. Auto-placement fills row-major. Each separator
     * spans both columns via grid-column: 1 / -1, drawing one continuous
     * hairline at its row position. Total grid rows: 4 (sep, cells, sep,
     * cells) — but auto rows means we don't have to declare them. */
    .home-stats__panel {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      column-gap: var(--nbg-sp-6);
      row-gap: var(--nbg-sp-3);
    }

    .home-stats__divider {
      grid-column: 1 / -1;
      height: 1px;
      background: var(--nbg-color-border-subtle);
    }

    .home-stats__cell {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-1);
      align-items: flex-start;
      min-width: 0;
    }

    .home-stats__value {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-display-md);
      font-weight: var(--nbg-fw-extrabold);
      font-feature-settings: var(--nbg-ff-features-tabular);
      font-variant-numeric: tabular-nums;
      font-variation-settings: 'opsz' var(--nbg-opsz-display);
      color: var(--nbg-color-fg-primary);
      letter-spacing: var(--nbg-ls-tight);
      line-height: 1;
    }

    .home-stats__label {
      margin: 0;
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-xs);
      letter-spacing: var(--nbg-ls-wide);
      text-transform: uppercase;
      color: var(--nbg-color-fg-muted);
    }

    @container nbg-section (min-width: 40rem) {
      .home-stats__panel {
        column-gap: var(--nbg-sp-8);
        row-gap: var(--nbg-sp-4);
      }
      .home-stats__value {
        font-size: var(--nbg-fs-display-lg);
      }
    }
  }
</style>
