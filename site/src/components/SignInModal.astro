---
// site/src/components/SignInModal.astro
//
// Global sign-in dialog. Single instance is mounted by SocialIconsOverride.astro
// so it ships with the header on every page. Opens in response to a
// `nbgaihub:open-signin-modal` custom event dispatched by the sign-in button.
//
// The PAT enters here only — we hand it to `auth.signIn(token)` which delegates
// validation + storage to the auth module. On `TokenInvalidError` we show the
// inline error; on other errors we show a generic network message. We never
// store, log, or echo the token from this component.
//
// A24: the deep-link to GitHub's token-create page uses target="_blank" with
// rel="noopener noreferrer".
---

<dialog
  class="nbg-signin"
  data-nbg-signin-dialog
  aria-labelledby="nbg-signin-title"
>
  <form method="dialog" class="nbg-signin__form" data-nbg-signin-form novalidate>
    <button
      type="button"
      class="nbg-signin__close"
      data-nbg-signin-close
      aria-label="Close"
    >
      &times;
    </button>

    <h2 id="nbg-signin-title" class="nbg-signin__title">Sign in to pin items</h2>

    <p class="nbg-signin__explainer">
      To pin pages and skills across devices, paste a GitHub Personal Access
      Token with the <code>gist</code> scope. The token is stored only in this
      browser's <code>localStorage</code> and is sent only to
      <code>api.github.com</code>.
    </p>

    <a
      class="nbg-signin__deeplink"
      href="https://github.com/settings/tokens/new?scopes=gist&description=NbgAiHub"
      target="_blank"
      rel="noopener noreferrer"
    >
      Create a token on GitHub &rarr;
    </a>

    <label class="nbg-signin__label" for="nbg-signin-token">
      Personal Access Token
    </label>
    <input
      id="nbg-signin-token"
      class="nbg-signin__input"
      data-nbg-signin-input
      type="password"
      autocomplete="off"
      spellcheck="false"
      placeholder="ghp_..."
      required
    />

    <p class="nbg-signin__error" data-nbg-signin-error role="alert" hidden></p>

    <div class="nbg-signin__actions">
      <button
        type="button"
        class="nbg-signin__btn nbg-signin__btn--secondary"
        data-nbg-signin-cancel
      >
        Cancel
      </button>
      <button
        type="submit"
        class="nbg-signin__btn nbg-signin__btn--primary"
        data-nbg-signin-submit
      >
        Validate &amp; sign in
      </button>
    </div>
  </form>
</dialog>

<style>
  /* P4.I restyle — tokens drive everything; the `<dialog>` chrome, every
   * data-nbg-signin-* attribute, aria-labelledby, and the script block are
   * preserved bit-for-bit (AC23 + AC34). DOM selectors (.nbg-signin,
   * .nbg-signin__form, .nbg-signin__input, etc.) are untouched. */
  @layer nbg.components {
    .nbg-signin {
      border: 1px solid var(--nbg-color-border-default);
      border-radius: var(--nbg-r-lg);
      padding: 0;
      background: var(--nbg-color-bg-elevated);
      color: var(--nbg-color-fg-primary);
      max-width: 32rem;
      width: calc(100% - var(--nbg-sp-8));
      box-shadow: var(--nbg-sh-xl);
    }
    .nbg-signin::backdrop {
      background: var(--nbg-color-bg-overlay);
      backdrop-filter: blur(4px);
    }

    .nbg-signin__form {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-3);
      padding: var(--nbg-sp-6) var(--nbg-sp-6) var(--nbg-sp-5);
      position: relative;
    }

    .nbg-signin__close {
      position: absolute;
      top: var(--nbg-sp-2);
      right: var(--nbg-sp-2);
      background: transparent;
      border: 0;
      color: var(--nbg-color-fg-secondary);
      font-size: 1.4rem;
      line-height: 1;
      cursor: pointer;
      padding: var(--nbg-sp-1) var(--nbg-sp-2);
      border-radius: var(--nbg-r-sm);
      transition: background-color var(--nbg-dur-fast) var(--nbg-ease-out),
                  color            var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .nbg-signin__close:hover {
      background: var(--nbg-color-bg-surface-hover);
      color: var(--nbg-color-fg-primary);
    }
    .nbg-signin__close:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    .nbg-signin__title {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-xl);
      font-weight: var(--nbg-fw-bold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-headline);
      color: var(--nbg-color-fg-primary);
    }

    .nbg-signin__explainer {
      margin: 0;
      font-size: var(--nbg-fs-sm);
      line-height: var(--nbg-lh-relaxed);
      color: var(--nbg-color-fg-secondary);
    }
    .nbg-signin__explainer code {
      background: var(--nbg-color-bg-surface);
      color: var(--nbg-color-accent-fg);
      padding: 0 var(--nbg-sp-1);
      border-radius: var(--nbg-r-xs);
      font-family: var(--nbg-type-mono);
      font-size: 0.9em;
    }

    .nbg-signin__deeplink {
      align-self: flex-start;
      color: var(--nbg-color-link);
      text-decoration: none;
      font-weight: var(--nbg-fw-semibold);
      font-size: var(--nbg-fs-sm);
    }
    .nbg-signin__deeplink:hover {
      color: var(--nbg-color-link-hover);
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }

    .nbg-signin__label {
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-sm);
      font-weight: var(--nbg-fw-semibold);
      color: var(--nbg-color-fg-secondary);
      margin-top: var(--nbg-sp-1);
    }

    .nbg-signin__input {
      width: 100%;
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      border: 1px solid var(--nbg-color-border-default);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-bg-page);
      color: var(--nbg-color-fg-primary);
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-sm);
      transition:
        border-color var(--nbg-dur-fast) var(--nbg-ease-out),
        box-shadow   var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .nbg-signin__input:focus-visible {
      outline: none;
      border-color: var(--nbg-color-accent);
      box-shadow: var(--nbg-sh-focus-ring);
    }

    .nbg-signin__error {
      margin: 0;
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-status-danger-bg);
      color: var(--nbg-color-status-danger-fg);
      font-size: var(--nbg-fs-sm);
      border: 1px solid var(--nbg-color-status-danger-fg);
    }

    .nbg-signin__actions {
      display: flex;
      gap: var(--nbg-sp-2);
      justify-content: flex-end;
      margin-top: var(--nbg-sp-2);
    }

    .nbg-signin__btn {
      padding: var(--nbg-sp-2) var(--nbg-sp-4);
      border-radius: var(--nbg-r-md);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-sm);
      font-weight: var(--nbg-fw-semibold);
      cursor: pointer;
      border: 1px solid var(--nbg-color-border-default);
      transition:
        background-color var(--nbg-dur-fast) var(--nbg-ease-out),
        border-color     var(--nbg-dur-fast) var(--nbg-ease-out),
        color            var(--nbg-dur-fast) var(--nbg-ease-out),
        box-shadow       var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .nbg-signin__btn:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
    .nbg-signin__btn--primary {
      background: var(--nbg-color-accent-strong);
      color: var(--nbg-color-fg-on-accent);
      border-color: var(--nbg-color-accent-strong);
    }
    .nbg-signin__btn--primary:hover:not(:disabled) {
      background: var(--nbg-color-accent-hover);
      border-color: var(--nbg-color-accent-hover);
    }
    .nbg-signin__btn--primary:disabled {
      opacity: 0.6;
      cursor: progress;
    }
    .nbg-signin__btn--secondary {
      background: transparent;
      color: var(--nbg-color-fg-secondary);
    }
    .nbg-signin__btn--secondary:hover:not(:disabled) {
      background: var(--nbg-color-bg-surface-hover);
      color: var(--nbg-color-fg-primary);
      border-color: var(--nbg-color-border-strong);
    }
  }
</style>

<script>
  // Bundled by Vite as a client module — import from the auth lib works here.
  import { signIn } from '../lib/auth.ts';
  import { TokenInvalidError } from '../lib/api-fetch.ts';

  type Refs = {
    dialog: HTMLDialogElement;
    form: HTMLFormElement;
    input: HTMLInputElement;
    error: HTMLElement;
    submit: HTMLButtonElement;
    closeBtn: HTMLButtonElement;
    cancelBtn: HTMLButtonElement;
  };

  function collect(): Refs | null {
    const dialog = document.querySelector<HTMLDialogElement>('[data-nbg-signin-dialog]');
    const form = document.querySelector<HTMLFormElement>('[data-nbg-signin-form]');
    const input = document.querySelector<HTMLInputElement>('[data-nbg-signin-input]');
    const error = document.querySelector<HTMLElement>('[data-nbg-signin-error]');
    const submit = document.querySelector<HTMLButtonElement>('[data-nbg-signin-submit]');
    const closeBtn = document.querySelector<HTMLButtonElement>('[data-nbg-signin-close]');
    const cancelBtn = document.querySelector<HTMLButtonElement>('[data-nbg-signin-cancel]');
    if (!dialog || !form || !input || !error || !submit || !closeBtn || !cancelBtn) {
      return null;
    }
    return { dialog, form, input, error, submit, closeBtn, cancelBtn };
  }

  function showError(refs: Refs, msg: string): void {
    refs.error.textContent = msg;
    refs.error.hidden = false;
  }

  function clearError(refs: Refs): void {
    refs.error.textContent = '';
    refs.error.hidden = true;
  }

  function close(refs: Refs): void {
    if (refs.dialog.open) refs.dialog.close();
    refs.input.value = '';
    clearError(refs);
    refs.submit.disabled = false;
  }

  function open(refs: Refs): void {
    clearError(refs);
    refs.input.value = '';
    refs.submit.disabled = false;
    // Native <dialog> handles focus + Esc-to-close on showModal().
    if (typeof refs.dialog.showModal === 'function') {
      refs.dialog.showModal();
    } else {
      // Old browser fallback — just toggle the `open` attribute.
      refs.dialog.setAttribute('open', '');
    }
    // Defer focus until after the dialog is on-screen.
    queueMicrotask(() => refs.input.focus());
  }

  async function onSubmit(refs: Refs, event: Event): Promise<void> {
    event.preventDefault();
    clearError(refs);
    const token = refs.input.value.trim();
    if (token === '') {
      showError(refs, 'Please paste your token.');
      return;
    }
    refs.submit.disabled = true;
    try {
      await signIn(token);
      close(refs);
      // Subscribers (e.g. SocialIconsOverride) re-render via auth.subscribe();
      // reload still helps any per-page personalization that doesn't subscribe.
      window.location.reload();
    } catch (err) {
      refs.submit.disabled = false;
      if (err instanceof TokenInvalidError) {
        showError(refs, 'Invalid token. Check the value and the `gist` scope.');
      } else {
        const msg = err instanceof Error ? err.message : String(err);
        showError(refs, `Network error: ${msg}`);
      }
    }
  }

  function init(): void {
    const refs = collect();
    if (!refs) return;

    document.addEventListener('nbgaihub:open-signin-modal', () => open(refs));

    refs.form.addEventListener('submit', (e) => {
      void onSubmit(refs, e);
    });

    refs.closeBtn.addEventListener('click', () => close(refs));
    refs.cancelBtn.addEventListener('click', () => close(refs));

    // Clicking on the backdrop closes the dialog.
    refs.dialog.addEventListener('click', (event) => {
      if (event.target === refs.dialog) close(refs);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
