---
// AudienceFilter.astro — Three-checkbox audience filter.
// See project-design.md §S.3.6 + §S.13.12 (AudienceFilter row).
//
// Visual restyle ONLY (AC23 + AC35 + A6). The wrapping <form> retains the
// `.audience-filter` class and `data-scope` attribute (read by the script
// verbatim). The three checkbox inputs stay real inputs — multi-select
// behaviour preserved. The script block below is unchanged bit-for-bit from
// the pre-redesign component. Only the surrounding label chrome changes to
// render as a segmented control via CSS tokens.

interface Props {
  scope?: string;
}

const { scope = '[data-audience]' } = Astro.props;
---

<form class="audience-filter not-content" data-scope={scope}>
  <span class="audience-filter__label">Audience</span>
  <div class="audience-filter__group" role="group" aria-label="Audience filter">
    <label class="audience-filter__option">
      <input type="checkbox" value="beginner" checked />
      <span class="audience-filter__chip">Beginner</span>
    </label>
    <label class="audience-filter__option">
      <input type="checkbox" value="advanced" checked />
      <span class="audience-filter__chip">Advanced</span>
    </label>
    <label class="audience-filter__option">
      <input type="checkbox" value="both" checked />
      <span class="audience-filter__chip">Both</span>
    </label>
  </div>
</form>

<style>
  @layer nbg.components {
    .audience-filter {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--nbg-sp-3);
      margin-block: var(--nbg-sp-4);
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      background: var(--nbg-color-bg-surface);
      border: 1px solid var(--nbg-color-border-subtle);
      border-radius: var(--nbg-r-md);
    }
    .audience-filter__label {
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-xs);
      font-weight: var(--nbg-fw-medium);
      letter-spacing: var(--nbg-ls-wide);
      text-transform: uppercase;
      color: var(--nbg-color-fg-muted);
    }
    .audience-filter__group {
      display: inline-flex;
      flex-wrap: wrap;
      gap: var(--nbg-sp-1);
      padding: var(--nbg-sp-1);
      background: var(--nbg-color-bg-page);
      border: 1px solid var(--nbg-color-border-subtle);
      border-radius: var(--nbg-r-pill);
    }
    .audience-filter__option {
      display: inline-flex;
      cursor: pointer;
      position: relative;
    }
    /* Visually hide the real input but keep it focusable for keyboard + AT. */
    .audience-filter__option input[type='checkbox'] {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      margin: 0;
      opacity: 0;
      cursor: pointer;
    }
    .audience-filter__chip {
      display: inline-flex;
      align-items: center;
      padding: var(--nbg-sp-1) var(--nbg-sp-3);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-xs);
      font-weight: var(--nbg-fw-medium);
      line-height: 1.3;
      color: var(--nbg-color-fg-secondary);
      background: transparent;
      border-radius: var(--nbg-r-pill);
      transition:
        background-color var(--nbg-dur-fast) var(--nbg-ease-out),
        color            var(--nbg-dur-fast) var(--nbg-ease-out);
      user-select: none;
    }
    .audience-filter__option:hover .audience-filter__chip {
      color: var(--nbg-color-fg-primary);
    }
    .audience-filter__option input[type='checkbox']:checked + .audience-filter__chip {
      background: var(--nbg-color-accent-bg);
      color: var(--nbg-color-accent-fg);
    }
    .audience-filter__option input[type='checkbox']:focus-visible + .audience-filter__chip {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
  }
</style>

<script is:inline>
  (function () {
    const KEY = 'nbgaihub.audience';
    const DEFAULT = ['beginner', 'advanced', 'both'];

    function applyAll() {
      document.querySelectorAll('.audience-filter').forEach(function (form) {
        const scope = form.getAttribute('data-scope') || '[data-audience]';
        const boxes = form.querySelectorAll('input[type="checkbox"]');
        const visible = new Set();
        boxes.forEach(function (b) {
          if (b.checked) visible.add(b.value);
        });
        document.querySelectorAll(scope).forEach(function (el) {
          const a = el.getAttribute('data-audience') || 'both';
          el.classList.toggle('audience-hidden', !visible.has(a));
        });
        try {
          localStorage.setItem(KEY, JSON.stringify(Array.from(visible)));
        } catch (e) {
          /* private-mode / quota: ignore */
        }
      });
    }

    function restore() {
      try {
        const raw = localStorage.getItem(KEY);
        const saved = raw ? JSON.parse(raw) : DEFAULT;
        document
          .querySelectorAll('.audience-filter input[type="checkbox"]')
          .forEach(function (box) {
            box.checked = saved.indexOf(box.value) !== -1;
          });
      } catch (e) {
        /* malformed or unavailable: keep defaults */
      }
    }

    function init() {
      restore();
      applyAll();
      document
        .querySelectorAll('.audience-filter input[type="checkbox"]')
        .forEach(function (box) {
          box.addEventListener('change', applyAll);
        });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
