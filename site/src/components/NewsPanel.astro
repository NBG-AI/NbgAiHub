---
// NewsPanel.astro — Top-N news cards for the homepage.
// See project-design.md §S.3.2 + §S.13.5.7.
//
// Public API preserved: optional `limit` prop (default 5). `getRecentNews(limit)`
// call unchanged. Internally composes <Stack> + <Card variant="feature"> for the
// lead news item + <Card variant="content"> for the rest. Asymmetric grid:
// lead spans the row on desktop, two-column grid below.

import Card from './primitives/Card.astro';
import Stack from './primitives/Stack.astro';
import Cluster from './primitives/Cluster.astro';
import Chip from './primitives/Chip.astro';
import Eyebrow from './primitives/Eyebrow.astro';
import AudienceBadge from './AudienceBadge.astro';
import ConfidenceChip from './ConfidenceChip.astro';
import PinButton from './PinButton.astro';
import { getRecentNews } from '../lib/news.ts';

interface Props {
  limit?: number;
}

const { limit = 5 } = Astro.props;
const items = await getRecentNews(limit);

const [lead, ...rest] = items;
---

<section class="news-panel not-content" data-news-panel>
  <header class="news-panel__header">
    <Eyebrow>Latest</Eyebrow>
    <h2 class="news-panel__title">News</h2>
  </header>

  {items.length === 0 ? (
    <Card variant="content">
      <p class="news-panel__empty">
        No items yet. See <a href="/contribute/">Contribute</a> for how to add one.
      </p>
    </Card>
  ) : (
    <div class="news-panel__grid">
      {lead && (
        <article
          class="news-panel__item news-panel__item--lead"
          data-audience={lead.data.audience}
          data-topics={lead.data.topics.join(',')}
        >
          <Card variant="feature">
            <Stack gap="3">
              <Cluster gap="2" align="center">
                <Eyebrow tone="accent">Lead story</Eyebrow>
              </Cluster>
              <h3 class="news-panel__item-title news-panel__item-title--lead">
                <a href={`/news/${lead.id}/`}>{lead.data.title}</a>
              </h3>
              <Cluster gap="2">
                <AudienceBadge audience={lead.data.audience} />
                <ConfidenceChip confidence={lead.data.editor_confidence} />
                <span class="news-panel__meta">{lead.data.source}</span>
                <span class="news-panel__meta">{lead.data.authored}</span>
              </Cluster>
              {lead.data.topics.length > 0 && (
                <Cluster gap="2">
                  {lead.data.topics.map((topic) => (
                    <Chip>{topic}</Chip>
                  ))}
                </Cluster>
              )}
              <Cluster gap="2" justify="end">
                <PinButton type="news" slug={lead.id} />
              </Cluster>
            </Stack>
          </Card>
        </article>
      )}

      {rest.map((item) => (
        <article
          class="news-panel__item"
          data-audience={item.data.audience}
          data-topics={item.data.topics.join(',')}
        >
          <Card variant="content">
            <Stack gap="2">
              <h3 class="news-panel__item-title">
                <a href={`/news/${item.id}/`}>{item.data.title}</a>
              </h3>
              <Cluster gap="2">
                <AudienceBadge audience={item.data.audience} />
                <ConfidenceChip confidence={item.data.editor_confidence} />
                <span class="news-panel__meta">{item.data.source}</span>
                <span class="news-panel__meta">{item.data.authored}</span>
              </Cluster>
              {item.data.topics.length > 0 && (
                <Cluster gap="2">
                  {item.data.topics.map((topic) => (
                    <Chip>{topic}</Chip>
                  ))}
                </Cluster>
              )}
              <Cluster gap="2" justify="end">
                <PinButton type="news" slug={item.id} />
              </Cluster>
            </Stack>
          </Card>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  @layer nbg.components {
    .news-panel {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-6);
      margin-block: var(--nbg-sp-8);
    }
    .news-panel__header {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-1);
    }
    .news-panel__title {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-2xl);
      font-weight: var(--nbg-fw-bold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-headline);
      color: var(--nbg-color-fg-primary);
    }
    .news-panel__grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--nbg-sp-5);
    }
    @media (min-width: 48rem) {
      .news-panel__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .news-panel__item--lead {
        grid-column: 1 / -1;
      }
    }
    .news-panel__item {
      min-width: 0;
    }
    .news-panel__item-title {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-xl);
      font-weight: var(--nbg-fw-semibold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-headline);
      color: var(--nbg-color-fg-primary);
    }
    .news-panel__item-title--lead {
      font-size: var(--nbg-fs-2xl);
    }
    .news-panel__item-title a {
      color: inherit;
      text-decoration: none;
    }
    .news-panel__item-title a:hover {
      color: var(--nbg-color-link-hover);
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }
    .news-panel__meta {
      color: var(--nbg-color-fg-muted);
      font-size: var(--nbg-fs-sm);
      font-family: var(--nbg-type-body);
    }
    .news-panel__empty {
      margin: 0;
      color: var(--nbg-color-fg-secondary);
    }
  }
</style>
