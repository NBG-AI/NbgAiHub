---
// ConfidenceChip.astro — Renders the editor_confidence value on news cards.
// See project-design.md §S.13.5.9.
//
// @deprecated — use <Badge tone={confidence}> from primitives directly.
// Kept in place during the Wave-2 redesign because consumers across pages
// import this component by name. Internally renders <Badge tone={confidence}>,
// so the legacy flat confidence colors are gone and the new tokenized
// semantic confidence tokens drive the visual. Wave 3 will delete this file.

import Badge from './primitives/Badge.astro';

interface Props {
  confidence: 'high' | 'medium' | 'low';
}

const { confidence } = Astro.props;
---

<Badge tone={confidence}>confidence: {confidence}</Badge>
