---
/**
 * Display.astro — Oversized display heading.
 *
 * Purpose: Polymorphic <h1>..<h4> via `level` prop. Engages Inter's `opsz`
 * (optical-size) axis at 32 for display-optimized glyph forms.
 *
 * Related: project-design.md §S.13.3 + §S.13.5.14.
 * Portability: zero Starlight imports — primitives consume only design tokens.
 * A11y: heading semantics from <h{level}> — `level` is required.
 */
type Level = 1 | 2 | 3 | 4;
type Size = 'sm' | 'md' | 'lg' | 'xl' | '2xl';
type Weight = 'medium' | 'semibold' | 'bold' | 'extrabold';

interface Props {
  level: Level;
  size?: Size;
  weight?: Weight;
}

const { level, size, weight } = Astro.props;

// Per global no-fallback rule — `level` is required; throw early on missing/invalid.
if (level !== 1 && level !== 2 && level !== 3 && level !== 4) {
  throw new Error('Display requires `level` prop in {1, 2, 3, 4}. See §S.13.5.14.');
}

// Size defaults are level-dependent (per §S.13.5.14).
const resolvedSize: Size = size
  ?? (level === 1 ? 'lg'
    : level === 2 ? 'md'
    : 'sm');

// Weight default depends on size — extrabold for very large, bold otherwise.
const resolvedWeight: Weight = weight
  ?? ((resolvedSize === 'xl' || resolvedSize === '2xl') ? 'extrabold' : 'bold');

const Tag = `h${level}` as 'h1' | 'h2' | 'h3' | 'h4';
---
<Tag class="nbg-display" data-size={resolvedSize} data-weight={resolvedWeight} data-display>
  <slot />
</Tag>

<style>
  @layer nbg.primitives {
    .nbg-display {
      margin: 0;
      font-family: var(--nbg-type-display);
      color: var(--nbg-color-fg-primary);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-display);
      font-variation-settings: 'opsz' var(--nbg-opsz-display);
      text-wrap: balance;
    }

    .nbg-display[data-size='sm']  { font-size: var(--nbg-fs-display-sm); }
    .nbg-display[data-size='md']  { font-size: var(--nbg-fs-display-md); }
    .nbg-display[data-size='lg']  { font-size: var(--nbg-fs-display-lg); }
    .nbg-display[data-size='xl']  { font-size: var(--nbg-fs-display-xl); }
    .nbg-display[data-size='2xl'] { font-size: var(--nbg-fs-display-2xl); }

    .nbg-display[data-weight='medium']    { font-weight: var(--nbg-fw-medium); }
    .nbg-display[data-weight='semibold']  { font-weight: var(--nbg-fw-semibold); }
    .nbg-display[data-weight='bold']      { font-weight: var(--nbg-fw-bold); }
    .nbg-display[data-weight='extrabold'] { font-weight: var(--nbg-fw-extrabold); }
  }
</style>
