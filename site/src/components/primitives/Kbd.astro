---
/**
 * Kbd.astro — Keyboard shortcut display.
 *
 * Purpose: Renders <kbd> with mono font and 1px border. Combine inside
 * <Cluster gap="1"> for a chord (e.g. <Kbd>Cmd</Kbd><Kbd>K</Kbd>).
 *
 * Related: project-design.md §S.13.2.4 + §S.13.5.11.
 * Portability: zero Starlight imports — primitives consume only design tokens.
 */
---
<kbd class="nbg-kbd"><slot /></kbd>

<style>
  @layer nbg.primitives {
    .nbg-kbd {
      --nbg-kbd-bg:      var(--nbg-color-bg-page);
      --nbg-kbd-fg:      var(--nbg-color-fg-secondary);
      --nbg-kbd-border:  var(--nbg-color-border-default);
      --nbg-kbd-radius:  var(--nbg-r-sm);

      display: inline-flex;
      align-items: center;
      padding: var(--nbg-sp-px) var(--nbg-sp-1-5);
      background: var(--nbg-kbd-bg);
      color: var(--nbg-kbd-fg);
      border: 1px solid var(--nbg-kbd-border);
      border-bottom-width: 2px;
      border-radius: var(--nbg-kbd-radius);
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-2xs);
      line-height: 1.3;
      font-feature-settings: 'zero' on, 'liga' off;
      white-space: nowrap;
    }
  }
</style>
