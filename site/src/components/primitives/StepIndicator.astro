---
/**
 * StepIndicator.astro — Vertical or sticky step list with current-step highlight.
 *
 * Purpose: Drives AC6 (Day-1 journey chapter layout). Sticky on desktop;
 * collapses to a horizontal scrollable strip below --nbg-bp-md (per §S.13.5.16).
 *
 * Behavior: an inline <script> uses IntersectionObserver to detect which
 * `section[id^='step-']` is in view; updates `[data-current]` on the nav <li>s.
 * The list-of-steps DOM is rendered at frontmatter-time.
 *
 * Related: project-design.md §S.13.5.16 + AC6.
 * Portability: zero Starlight imports — primitives consume only design tokens.
 * A11y: <nav aria-label>; current step gets aria-current="true".
 */
interface Step {
  id: string;
  label: string;
}

interface Props {
  steps: Step[];
  current?: string;
  sticky?: boolean;
  ariaLabel?: string;
}

const { steps, current, sticky = true, ariaLabel = 'Steps' } = Astro.props;

if (!Array.isArray(steps) || steps.length === 0) {
  throw new Error('StepIndicator requires a non-empty `steps` array.');
}
---
<nav class="nbg-step-indicator" data-sticky={String(sticky)} aria-label={ariaLabel}>
  <ol>
    {steps.map((step, index) => {
      const isCurrent = step.id === current;
      return (
        <li
          data-step-id={step.id}
          data-current={isCurrent ? 'true' : 'false'}
        >
          <a
            href={`#${step.id}`}
            aria-current={isCurrent ? 'true' : undefined}
          >
            <span class="nbg-step-indicator__number">{index + 1}</span>
            <span class="nbg-step-indicator__label">{step.label}</span>
          </a>
        </li>
      );
    })}
  </ol>
</nav>

<style>
  @layer nbg.primitives {
    .nbg-step-indicator {
      font-family: var(--nbg-type-body);
      color: var(--nbg-color-fg-secondary);
    }
    .nbg-step-indicator[data-sticky='true'] {
      position: sticky;
      top: var(--nbg-sp-8);
      align-self: start;
    }
    .nbg-step-indicator ol {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-2);
    }
    .nbg-step-indicator li {
      position: relative;
    }
    .nbg-step-indicator a {
      display: flex;
      align-items: center;
      gap: var(--nbg-sp-3);
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      border-radius: var(--nbg-r-md);
      color: var(--nbg-color-fg-muted);
      text-decoration: none;
      transition:
        background-color var(--nbg-dur-fast) var(--nbg-ease-out),
        color            var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .nbg-step-indicator a:hover {
      background: var(--nbg-color-bg-surface-hover);
      color: var(--nbg-color-fg-primary);
    }
    .nbg-step-indicator a:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
    .nbg-step-indicator li[data-current='true'] a {
      background: var(--nbg-color-accent-bg);
      color: var(--nbg-color-accent-fg);
    }
    .nbg-step-indicator__number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: var(--nbg-sp-6);
      height: var(--nbg-sp-6);
      border-radius: var(--nbg-r-pill);
      background: var(--nbg-color-bg-surface);
      border: 1px solid var(--nbg-color-border-default);
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-xs);
      font-weight: var(--nbg-fw-semibold);
      flex: 0 0 auto;
    }
    .nbg-step-indicator li[data-current='true'] .nbg-step-indicator__number {
      background: var(--nbg-color-accent);
      color: var(--nbg-color-fg-on-accent);
      border-color: var(--nbg-color-accent);
    }
    .nbg-step-indicator__label {
      font-size: var(--nbg-fs-sm);
      font-weight: var(--nbg-fw-medium);
    }

    /* Mobile — horizontal scrollable strip below --nbg-bp-md. */
    @media (max-width: 63.999rem) {
      .nbg-step-indicator[data-sticky='true'] {
        position: static;
      }
      .nbg-step-indicator ol {
        flex-direction: row;
        overflow-x: auto;
        scroll-snap-type: x proximity;
        gap: var(--nbg-sp-1);
        padding-bottom: var(--nbg-sp-2);
      }
      .nbg-step-indicator li {
        scroll-snap-align: start;
        flex: 0 0 auto;
      }
      .nbg-step-indicator a {
        white-space: nowrap;
      }
    }
  }
</style>

<script>
  // IntersectionObserver to update [data-current] as the user scrolls.
  // Skips under prefers-reduced-motion only for smooth scrolling, not for the
  // attribute toggle (which is non-animated and useful for orientation).
  (() => {
    const indicators = document.querySelectorAll<HTMLElement>('.nbg-step-indicator');
    if (indicators.length === 0) return;

    for (const indicator of indicators) {
      const links = indicator.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');
      const sections: HTMLElement[] = [];
      for (const link of links) {
        const id = link.getAttribute('href')?.slice(1);
        if (!id) continue;
        const section = document.getElementById(id);
        if (section) sections.push(section);
      }
      if (sections.length === 0) continue;

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            const id = entry.target.id;
            const lis = indicator.querySelectorAll<HTMLElement>('li[data-step-id]');
            for (const li of lis) {
              const isCurrent = li.dataset.stepId === id;
              li.dataset.current = isCurrent ? 'true' : 'false';
              const a = li.querySelector('a');
              if (a) {
                if (isCurrent) {
                  a.setAttribute('aria-current', 'true');
                } else {
                  a.removeAttribute('aria-current');
                }
              }
            }
          }
        },
        { rootMargin: '-30% 0px -60% 0px', threshold: 0 },
      );

      for (const section of sections) observer.observe(section);
    }
  })();
</script>
