---
/**
 * /tips — AgentNews-aesthetic tips index.
 *
 * Thematic clustering: prompting / survival / context / compliance, derived
 * from `topics` frontmatter with a small fallback table.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #4.
 * Backs AC10, AC15.
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import MarketingShell from '../components/MarketingShell.astro';
import AudienceFilter from '../components/AudienceFilter.astro';
import PinButton from '../components/PinButton.astro';
import { linkGlossaryTerms } from '../lib/glossary-link-string';

type Tip = CollectionEntry<'tips'>;

const all = await getCollection('tips');

// Cluster heuristic — derive from topics. Order matters (first match wins).
const CLUSTERS: Array<{ key: string; label: string; tag: string; match: (t: Tip) => boolean }> = [
  { key: 'prompting',  label: 'Prompting',  tag: 'Prompting',
    match: (t) => t.data.topics.some((x: string) => /prompt|model|opus|sonnet/i.test(x)) },
  { key: 'survival',   label: 'Survival keys', tag: 'Survival',
    match: (t) => t.data.topics.some((x: string) => /survival|esc|compact|clear|keyboard/i.test(x)) },
  { key: 'context',    label: 'Context discipline', tag: 'Context',
    match: (t) => t.data.topics.some((x: string) => /context|memory|claudemd|claude\.md|file/i.test(x)) },
  { key: 'compliance', label: 'Compliance + safety', tag: 'Compliance',
    match: (t) => t.data.topics.some((x: string) => /compliance|safety|trust|review|azure|secrets/i.test(x)) },
];

const buckets: Record<string, Tip[]> = Object.fromEntries(CLUSTERS.map((c) => [c.key, []]));
const orphans: Tip[] = [];
for (const tip of all) {
  const cluster = CLUSTERS.find((c) => c.match(tip));
  if (cluster) {
    const bucket = buckets[cluster.key];
    if (bucket) bucket.push(tip);
  } else {
    orphans.push(tip);
  }
}
---

<MarketingShell
  title="Tips"
  description="Tips, prompts, and gotchas — the patterns we keep reaching for."
  surfaceId="tips"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Patterns I keep <em>reaching for.</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms("Prompts, gotchas, and workflow recipes — clustered by theme so you can skim the area you need. Opinionated and plainspoken.")} />
          <small>{all.length} entries</small>
        </p>
      </div>
      <div style="margin-top: 2rem;">
        <AudienceFilter scope=".card[data-audience]" />
      </div>
    </div>
  </section>

  {CLUSTERS.map((cluster) => {
    const items = buckets[cluster.key] ?? [];
    if (items.length === 0) return null;
    return (
      <section class="section" id={cluster.key}>
        <div class="wrap">
          <div class="section__head">
            <h2>{cluster.label}</h2>
            <span class="count">{items.length} {items.length === 1 ? 'tip' : 'tips'}</span>
          </div>
          <div class="grid-3">
            {items.map((tip) => (
              <article class="card card--text" data-audience={tip.data.audience}>
                <div class="card__body">
                  <div class="card__meta">
                    <span class="tag tag--link">{cluster.tag}</span>
                    <span class={`tag tag--audience-${tip.data.audience}`}>{tip.data.audience}</span>
                  </div>
                  <h3 class="card__title">{tip.data.title}</h3>
                  <p class="card__summary" set:html={linkGlossaryTerms(tip.data.ai_summary)} />
                  <div style="margin-top: 0.5rem;">
                    <PinButton type="tip" slug={tip.id} />
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    );
  })}

  {orphans.length > 0 && (
    <section class="section" id="other">
      <div class="wrap">
        <div class="section__head">
          <h2>Other</h2>
          <span class="count">{orphans.length} {orphans.length === 1 ? 'tip' : 'tips'}</span>
        </div>
        <div class="grid-3">
          {orphans.map((tip) => (
            <article class="card card--text" data-audience={tip.data.audience}>
              <div class="card__body">
                <div class="card__meta">
                  <span class="tag">Misc</span>
                </div>
                <h3 class="card__title">{tip.data.title}</h3>
                <p class="card__summary">{tip.data.ai_summary}</p>
                <div style="margin-top: 0.5rem;">
                  <PinButton type="tip" slug={tip.id} />
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</MarketingShell>

<style>
  @layer nbg.components {
    .card.audience-hidden { display: none; }
  }
</style>
