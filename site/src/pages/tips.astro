---
/**
 * /tips — single-column reading flow, structural twin of /skills.
 *
 * 2026-05-25 late-night UAT redesign (round 2):
 *   - Hero scale lifted to match Foundations (.hero hero--stack).
 *   - Audience filter integrated into the hero instead of sitting in its own
 *     bordered box below.
 *   - Cluster headers use the same eyebrow/title vocabulary as Foundations
 *     section heads.
 *   - Each row gets an eyebrow, serif title, summary, quiet pills bottom-right,
 *     and a hover-revealed pin icon in the top-right corner.
 *   - Pin icon is opacity 0 by default and reveals on row hover. Clicking it
 *     when signed-out opens the redesigned sign-in modal.
 *
 * Cluster heuristic preserved from the previous file — `topics` frontmatter
 * decides bucket, fallback "Other".
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import MarketingShell from '../components/MarketingShell.astro';
import AudienceFilter from '../components/AudienceFilter.astro';
import TopicFilter from '../components/TopicFilter.astro';
import PinButton from '../components/PinButton.astro';
import { linkGlossaryTerms } from '../lib/glossary-link-string';
import '../styles/listing-rows.css';
import '../styles/tip-preview.css';

type Tip = CollectionEntry<'tips'>;

const all = await getCollection('tips');

// 2026-05-29: pre-render every tip body to HTML at build time so the listing
// page's hover-preview popover can show the same prose the detail page
// renders. Uses a small inline markdown-to-HTML pass rather than the project
// remark processor — keeps the popover lightweight and avoids 27 extra
// glossary index reads at build time.
function escapeHtml(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}
function inlineMd(s: string): string {
  let out = '';
  let i = 0;
  while (i < s.length) {
    const tick = s.indexOf('`', i);
    if (tick === -1) { out += s.slice(i); break; }
    out += s.slice(i, tick);
    const end = s.indexOf('`', tick + 1);
    if (end === -1) { out += s.slice(tick); break; }
    out += `<code>${s.slice(tick + 1, end)}</code>`;
    i = end + 1;
  }
  out = out.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
  out = out.replace(/(^|[\s(])_([^_]+)_(?=$|[\s.,;:!?)])/g, '$1<em>$2</em>');
  out = out.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (_m, t, u) => `<a href="${String(u).replace(/"/g, '&quot;')}">${t}</a>`);
  return out;
}
function simpleMarkdown(md: string): string {
  const lines = md.split('\n');
  const out: string[] = [];
  let i = 0;
  while (i < lines.length) {
    const line = lines[i] ?? '';
    if (line.startsWith('```')) {
      const buf: string[] = [];
      i++;
      while (i < lines.length && !(lines[i] ?? '').startsWith('```')) {
        buf.push(lines[i] ?? '');
        i++;
      }
      i++;
      out.push(`<pre><code>${escapeHtml(buf.join('\n'))}</code></pre>`);
      continue;
    }
    const h = line.match(/^(#{2,4})\s+(.*)$/);
    if (h && h[1] && h[2]) {
      out.push(`<h${h[1].length}>${inlineMd(escapeHtml(h[2]))}</h${h[1].length}>`);
      i++;
      continue;
    }
    if (line.startsWith('> ')) {
      const buf: string[] = [];
      while (i < lines.length && (lines[i] ?? '').startsWith('> ')) {
        buf.push((lines[i] ?? '').slice(2));
        i++;
      }
      out.push(`<blockquote><p>${inlineMd(escapeHtml(buf.join(' ')))}</p></blockquote>`);
      continue;
    }
    if (/^[-*]\s+/.test(line)) {
      const items: string[] = [];
      while (i < lines.length && /^[-*]\s+/.test(lines[i] ?? '')) {
        items.push(`<li>${inlineMd(escapeHtml((lines[i] ?? '').replace(/^[-*]\s+/, '')))}</li>`);
        i++;
      }
      out.push(`<ul>${items.join('')}</ul>`);
      continue;
    }
    if (/^\d+\.\s+/.test(line)) {
      const items: string[] = [];
      while (i < lines.length && /^\d+\.\s+/.test(lines[i] ?? '')) {
        items.push(`<li>${inlineMd(escapeHtml((lines[i] ?? '').replace(/^\d+\.\s+/, '')))}</li>`);
        i++;
      }
      out.push(`<ol>${items.join('')}</ol>`);
      continue;
    }
    if (line.trim() === '') { i++; continue; }
    const buf: string[] = [];
    while (i < lines.length && (lines[i] ?? '').trim() !== '') {
      const lp = lines[i] ?? '';
      if (lp.startsWith('```') || /^#{2,4}\s+/.test(lp) || /^[-*]\s+/.test(lp) || /^\d+\.\s+/.test(lp) || lp.startsWith('> ')) break;
      buf.push(lp);
      i++;
    }
    if (buf.length > 0) out.push(`<p>${inlineMd(escapeHtml(buf.join(' ')))}</p>`);
  }
  return out.join('\n');
}

const renderedBodies = new Map<string, string>();
for (const tip of all) {
  if (typeof tip.body === 'string' && tip.body.trim().length > 0) {
    renderedBodies.set(tip.id, simpleMarkdown(tip.body));
  }
}

// Distinct topic values across the tips collection. The frontmatter
// schema (`content.config.ts` → `tipTopicEnum`) restricts topics to the
// canonical five — prompting / workflow / context / control / safety —
// so this list is bounded by definition and needs no exclusion filter.
const allTopics = Array.from(new Set(all.flatMap((t) => t.data.topics))).sort();

// 2026-05-28 — exact topic membership instead of substring regex. The previous
// /prompt|model|opus|sonnet/ pattern was matching "trust-model" as a substring
// and pulling always-review-changes into Prompting by accident. Tag-based
// membership is explicit; if a tag isn't listed, the tip falls to Other.
const hasAny = (topics: string[], wanted: string[]): boolean =>
  topics.some((t) => wanted.includes(t.toLowerCase()));

// Cluster order = topic-chip filter ordering on the page body. A tip
// falls into the FIRST cluster whose `match` returns true, so when a
// tip carries two canonical topics (e.g. `[control, workflow]`), the
// ordering here decides which section it appears under. The `match`
// values mirror the canonical topic enum in `content.config.ts`.
const CLUSTERS: Array<{ key: string; label: string; blurb: string; match: (t: Tip) => boolean }> = [
  {
    key: 'prompting',
    label: 'Prompting',
    blurb: 'How to ask — phrasing, structure, what to include.',
    match: (t) => hasAny(t.data.topics, ['prompting']),
  },
  {
    key: 'control',
    label: 'Control keys',
    blurb: 'The keystrokes and modes that put you back in the driver seat — stop, undo, switch what Claude is allowed to do.',
    match: (t) => hasAny(t.data.topics, ['control']),
  },
  {
    key: 'workflow',
    label: 'Workflow & commands',
    blurb: 'How to drive Claude Code — plan-first, slash commands, sessions, subagents, hooks. The shortcuts that compound.',
    match: (t) => hasAny(t.data.topics, ['workflow']),
  },
  {
    key: 'context',
    label: 'Context discipline',
    blurb: 'Keeping Claude focused — what stays in the conversation, what should be cleared.',
    match: (t) => hasAny(t.data.topics, ['context']),
  },
  {
    key: 'compliance',
    label: 'Compliance & safety',
    blurb: 'Working with bank data and external services — what is allowed and what is not.',
    match: (t) => hasAny(t.data.topics, ['safety']),
  },
];

const buckets: Record<string, Tip[]> = Object.fromEntries(CLUSTERS.map((c) => [c.key, []]));
const orphans: Tip[] = [];
for (const tip of all) {
  const cluster = CLUSTERS.find((c) => c.match(tip));
  if (cluster) {
    const bucket = buckets[cluster.key];
    if (bucket) bucket.push(tip);
  } else {
    orphans.push(tip);
  }
}

function audienceTooltip(a: string): string {
  if (a === 'beginner') return 'For colleagues new to Claude Code';
  if (a === 'advanced') return 'For experienced Claude Code users';
  return 'Applies to everyone';
}
---

<MarketingShell
  title="Tips"
  description="Tips, prompts, and gotchas — the patterns we keep reaching for."
  surfaceId="tips"
  width="full"
  hero="none"
>
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Patterns I keep <em>reaching for</em></h1>
        <p class="hero__lede">
          <Fragment set:html={linkGlossaryTerms("Prompts, gotchas, and workflow recipes — clustered by theme so you can skim the area you need. Opinionated and plainspoken.")} />
        </p>
      </div>
    </div>
  </section>

  {/* Sticky filter strip — sibling of the listing sections so it stays
      visible through the entire scroll. Inner `.hero__filter` retains
      the existing chip layout styling. */}
  <section class="listing-filter-bar" data-listing-filter-bar>
    <div class="wrap">
      <div class="hero__filter">
        <AudienceFilter scope=".listing-row[data-audience]" />
        <TopicFilter topics={allTopics} scope=".listing-row[data-topics]" />
      </div>
    </div>
  </section>

  {/* 2026-06-02 — two-column shell. Left = listing sections (clusters +
      orphans + empty-state host). Right = sticky preview pane that
      updates on row hover. Collapses to single column ≤1100px viewport
      (see `.tips-shell` CSS); the preview pane is `display: none` there
      and rows fall back to title click-through as the sole affordance. */}
  <div class="tips-shell">
  <div class="tips-shell__main">

  {CLUSTERS.map((cluster) => {
    const items = buckets[cluster.key] ?? [];
    if (items.length === 0) return null;
    return (
      <section class="section section--listing" id={cluster.key} data-listing-section>
        <div class="wrap">
          <header class="listing-section__head">
            <h2 class="listing-section__title">{cluster.label}</h2>
            <p class="listing-section__lede">{cluster.blurb}</p>
          </header>
          <ul class="listing-list listing-list--compact" role="list">
            {items.map((tip) => (
              <li>
                <article
                  id={`tip-${tip.id}`}
                  class="listing-row listing-row--linked"
                  data-audience={tip.data.audience}
                  data-topics={tip.data.topics.join(',')}
                  data-tip-slug={tip.id}
                >
                  <div class="listing-row__main">
                    <p class="listing-row__eyebrow">
                      Tip <span class="listing-row__eyebrow-sep">·</span> {cluster.label}
                    </p>
                    <h3 class="listing-row__title">
                      <a href={`/tips/${tip.id}/`} class="listing-row__title-link">{tip.data.title}</a>
                    </h3>
                    <p class="listing-row__summary" set:html={linkGlossaryTerms(tip.data.ai_summary)} />
                  </div>
                  <div class="listing-row__meta">
                    <span
                      class={`listing-pill listing-pill--audience listing-pill--audience-${tip.data.audience}`}
                      title={audienceTooltip(tip.data.audience)}
                    >
                      {tip.data.audience}
                    </span>
                    <div class="listing-row__pin">
                      <PinButton type="tip" slug={tip.id} iconOnly={true} />
                    </div>
                  </div>
                  {renderedBodies.has(tip.id) && (
                    <script
                      type="text/x-tip-body"
                      class="tip-body-template"
                      data-tip-body-slug={tip.id}
                      set:html={renderedBodies.get(tip.id)}
                    />
                  )}
                </article>
              </li>
            ))}
          </ul>
        </div>
      </section>
    );
  })}

  {orphans.length > 0 && (
    <section class="section section--listing" id="other" data-listing-section>
      <div class="wrap">
        <header class="listing-section__head">
          <h2 class="listing-section__title">Other</h2>
          <p class="listing-section__lede">Patterns that don't fit neatly elsewhere.</p>
        </header>
        <ul class="listing-list" role="list">
          {orphans.map((tip) => (
            <li>
              <article
                id={`tip-${tip.id}`}
                class="listing-row listing-row--linked"
                data-audience={tip.data.audience}
                data-topics={tip.data.topics.join(',')}
                data-tip-slug={tip.id}
              >
                <div class="listing-row__main">
                  <p class="listing-row__eyebrow">Tip <span class="listing-row__eyebrow-sep">·</span> Other</p>
                  <h3 class="listing-row__title">
                    <a href={`/tips/${tip.id}/`} class="listing-row__title-link">{tip.data.title}</a>
                  </h3>
                  <p class="listing-row__summary" set:html={linkGlossaryTerms(tip.data.ai_summary)} />
                </div>
                <div class="listing-row__meta">
                  <span
                    class={`listing-pill listing-pill--audience listing-pill--audience-${tip.data.audience}`}
                    title={audienceTooltip(tip.data.audience)}
                  >
                    {tip.data.audience}
                  </span>
                  <div class="listing-row__pin">
                    <PinButton type="tip" slug={tip.id} iconOnly={true} />
                  </div>
                </div>
                {renderedBodies.has(tip.id) && (
                  <script
                    type="text/x-tip-body"
                    class="tip-body-template"
                    data-tip-body-slug={tip.id}
                    set:html={renderedBodies.get(tip.id)}
                  />
                )}
              </article>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section class="section section--listing" data-listing-empty-host>
    <div class="wrap">
      <aside class="listing-empty" id="listing-empty" aria-live="polite">
        <p class="listing-empty__title">No tips match these filters</p>
        <p class="listing-empty__body">Try a different audience, or clear the topic chips.</p>
        <button type="button" class="listing-empty__action" data-listing-clear-all>Clear filters</button>
      </aside>
    </div>
  </section>

  </div>{/* /.tips-shell__main */}

  {/* Sticky preview pane — populated by the hover script below. Carries
      a quiet placeholder at rest so the column doesn't look broken at
      first load. Hidden on coarse-pointer + narrow viewports via CSS. */}
  <aside
    id="tip-preview-pane"
    class="tip-preview tip-preview--pane"
    data-state="empty"
    aria-live="polite"
    aria-label="Tip preview"
  >
    <div class="tip-preview-pane__placeholder" data-tip-preview-placeholder>
      <p class="tip-preview__eyebrow">Tip preview</p>
      <p class="tip-preview-pane__hint">Hover a tip on the left to read the full text. Click the title to open its own page.</p>
    </div>
    <div class="tip-preview-pane__content" data-tip-preview-content hidden></div>
  </aside>

  </div>{/* /.tips-shell */}

  <script is:inline>
    (function () {
      // 2026-05-28 UX rethink — section-emptiness coordinator.
      // Filters add `audience-hidden` / `topic-hidden` to rows; this script
      // listens for the `nbg:filters-changed` event each filter dispatches,
      // counts visible rows per section, and toggles `is-empty` on sections
      // that have zero visible rows. When every section is empty, surfaces
      // the no-results aside.

      function recompute() {
        const sections = document.querySelectorAll('[data-listing-section]');
        let totalVisible = 0;
        sections.forEach(function (sec) {
          const rows = sec.querySelectorAll('.listing-row');
          let visible = 0;
          rows.forEach(function (r) {
            if (
              !r.classList.contains('audience-hidden') &&
              !r.classList.contains('topic-hidden')
            ) {
              visible += 1;
            }
          });
          sec.classList.toggle('is-empty', visible === 0);
          totalVisible += visible;
        });
        const empty = document.getElementById('listing-empty');
        if (empty) {
          empty.setAttribute('data-visible', totalVisible === 0 ? 'true' : 'false');
        }
        // Hide the host section entirely when there ARE visible rows, so the
        // empty wrapper doesn't add a phantom border-divider beneath the list.
        const host = document.querySelector('[data-listing-empty-host]');
        if (host) {
          host.classList.toggle('is-empty', totalVisible !== 0);
        }
      }

      function init() {
        // Wire the "Clear filters" button — resets both filters in one click.
        const clearAll = document.querySelector('[data-listing-clear-all]');
        if (clearAll) {
          clearAll.addEventListener('click', function () {
            // Reset audience radio to "all".
            const allRadio = document.querySelector(
              '.audience-filter input[type="radio"][value="all"]'
            );
            if (allRadio) {
              allRadio.checked = true;
              allRadio.dispatchEvent(new Event('change', { bubbles: true }));
            }
            // Reset topic chips to unpressed and fire the clear button.
            const topicClear = document.querySelector('[data-topic-clear]');
            if (topicClear) topicClear.click();
          });
        }
        document.addEventListener('nbg:filters-changed', recompute);
        recompute();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  {/* Sticky preview pane wiring.
       Each `.listing-row[data-tip-slug]` carries a hidden
       `<script type="text/x-tip-body">` with its pre-rendered body. On row
       hover the script below copies that content into the sticky pane
       declared above (#tip-preview-pane), swapping in the placeholder
       when no row is active. Disabled on coarse-pointer (touch) devices
       and on narrow viewports — those tap-to-navigate via the
       stretched-link overlay; the pane itself is `display:none` there. */}
  <script is:inline>
    (function () {
      var pane = document.getElementById('tip-preview-pane');
      if (!pane) return;
      // Skip wiring on touch — the pane is also display:none in CSS for
      // narrow viewports, but skipping the listeners avoids dead work.
      if (window.matchMedia && window.matchMedia('(hover: none), (pointer: coarse)').matches) {
        return;
      }
      var rows = document.querySelectorAll('.listing-row[data-tip-slug]');
      if (!rows.length) return;

      var placeholder = pane.querySelector('[data-tip-preview-placeholder]');
      var content = pane.querySelector('[data-tip-preview-content]');
      var activeRow = null;
      var clearTimer = null;

      function showRow(row) {
        var template = row.querySelector('.tip-body-template');
        if (!template) return;
        var bodyHtml = template.textContent || '';
        if (!bodyHtml.trim()) return;
        var titleNode = row.querySelector('.listing-row__title-link');
        var titleText = titleNode ? (titleNode.textContent || '').trim() : '';
        activeRow = row;
        content.innerHTML =
          '<header class="tip-preview__head">' +
            '<p class="tip-preview__eyebrow">Tip preview</p>' +
            '<h3 class="tip-preview__title"></h3>' +
          '</header>' +
          '<div class="tip-preview__body"></div>';
        var titleEl = content.querySelector('.tip-preview__title');
        if (titleEl) titleEl.textContent = titleText;
        var bodyEl = content.querySelector('.tip-preview__body');
        if (bodyEl) bodyEl.innerHTML = bodyHtml;
        if (placeholder) placeholder.hidden = true;
        content.hidden = false;
        pane.setAttribute('data-state', 'showing');
        // Scroll the pane back to top so each new tip starts fresh.
        pane.scrollTop = 0;
      }
      function restorePlaceholder() {
        activeRow = null;
        content.innerHTML = '';
        content.hidden = true;
        if (placeholder) placeholder.hidden = false;
        pane.setAttribute('data-state', 'empty');
      }

      rows.forEach(function (row) {
        row.addEventListener('mouseenter', function () {
          if (clearTimer) { clearTimeout(clearTimer); clearTimer = null; }
          showRow(row);
        });
        row.addEventListener('mouseleave', function () {
          // Short delay so moving between adjacent rows doesn't flash
          // the placeholder between hovers.
          clearTimer = setTimeout(function () {
            if (!activeRow || activeRow.matches(':hover')) return;
            restorePlaceholder();
          }, 180);
        });
      });
      // Allow hovering the pane itself (e.g. to scroll a long body) without
      // collapsing back to the placeholder.
      pane.addEventListener('mouseenter', function () {
        if (clearTimer) { clearTimeout(clearTimer); clearTimer = null; }
      });
      pane.addEventListener('mouseleave', function () {
        clearTimer = setTimeout(restorePlaceholder, 120);
      });
    })();
  </script>
</MarketingShell>

<script>
  import '../scripts/sticky-filter-bar.ts';
</script>
