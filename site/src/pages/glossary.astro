---
/**
 * /glossary — AgentNews-aesthetic filterable glossary with A-Z strip.
 *
 * Filter behaviour preserved: <input data-glossary-filter> + `[data-term]`
 * markers consumed by site/src/scripts/glossary-filter.ts which sets
 * `[hidden]` on non-matching <article>.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #5.
 * Backs AC10, AC15. Preserves filter test floor.
 */
import { getCollection, render } from 'astro:content';
import MarketingShell from '../components/MarketingShell.astro';
import PinButton from '../components/PinButton.astro';

const items = await getCollection('glossary');
const sorted = items.sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const rendered = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    const label = entry.data.title.toLowerCase();
    const firstLetter = label.charAt(0);
    return { entry, Content, label, firstLetter };
  }),
);

const lettersWithEntries = new Set(rendered.map((r) => r.firstLetter));
const alphabet = 'abcdefghijklmnopqrstuvwxyz'.split('');
---

<MarketingShell
  title="Glossary"
  description="Plain-language definitions for the Claude Code vocabulary."
  surfaceId="glossary"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">The Claude Code <em>vocabulary.</em></h1>
        <p class="hero__lede">
          Plain-language definitions for the words that keep coming up.
          Link directly to any term with <code>/glossary#&lt;slug&gt;</code>.
          <small>{items.length} terms</small>
        </p>
      </div>
    </div>
  </section>

  {rendered.length === 0 ? (
    <section class="section">
      <div class="wrap">
        <div class="empty">
          <p class="empty__eyebrow">No items yet</p>
          <h2 class="empty__title">The glossary is empty.</h2>
          <p class="empty__body">
            See <a href="/contribute/">Contribute</a> for how to add one.
          </p>
        </div>
      </div>
    </section>
  ) : (
    <>
      {/* Filter + A-Z strip */}
      <section class="section" id="glossary-rail" style="padding-block: 1.5rem;">
        <div class="wrap">
          <div class="glossary-rail">
            <input
              type="search"
              data-glossary-filter
              aria-label="Filter glossary"
              placeholder="Filter terms…"
              class="glossary-filter-input"
              autocomplete="off"
              spellcheck="false"
            />
            <div class="glossary-letters">
              {alphabet.map((letter) => {
                const hasEntry = lettersWithEntries.has(letter);
                return (
                  <a
                    href={`#letter-${letter}`}
                    data-letter={letter}
                    data-empty={hasEntry ? undefined : 'true'}
                    class="glossary-letter"
                    aria-label={`Jump to terms starting with ${letter.toUpperCase()}`}
                  >
                    {letter.toUpperCase()}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      </section>

      {/* Terms */}
      <section class="section" id="glossary-list">
        <div class="wrap">
          <div class="section__head">
            <h2>Terms</h2>
            <span class="count">{rendered.length} entries</span>
          </div>
          <div class="glossary-terms">
            {rendered.map(({ entry, Content, label, firstLetter }) => (
              <article
                id={entry.id}
                data-term
                data-term-label={label}
                class="glossary-term"
              >
                <span class="glossary-anchor" id={`letter-${firstLetter}`} aria-hidden="true" />
                <div class="glossary-term__head">
                  <span class="eyebrow eyebrow--accent">{firstLetter.toUpperCase()}</span>
                  <h3 class="card__title">
                    <a class="glossary-term-link" href={`#${entry.id}`} aria-label={`Anchor for ${entry.data.title}`}>
                      {entry.data.title}
                    </a>
                  </h3>
                </div>
                <div class="glossary-body sl-markdown-content">
                  <Content />
                </div>
                <div class="glossary-term__footer">
                  <PinButton type="glossary" slug={entry.id} />
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    </>
  )}
</MarketingShell>

<style>
  @layer nbg.components {
    .glossary-rail {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      position: sticky;
      top: 4.5rem;
      z-index: 1;
      padding: 1.25rem 1.5rem;
      background: var(--nbg-surface);
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-lg);
      box-shadow: var(--nbg-shadow-md);
    }
    .glossary-filter-input {
      width: 100%;
      max-width: 28rem;
      padding: 0.5rem 0.75rem;
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      color: var(--nbg-ink);
      background: var(--nbg-bg);
      border: 1px solid var(--nbg-border);
      border-radius: var(--nbg-r-md);
    }
    .glossary-filter-input:focus-visible {
      outline: 2px solid var(--nbg-accent);
      outline-offset: 2px;
      border-color: var(--nbg-accent);
    }
    .glossary-letters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
    }
    .glossary-letter {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.75rem;
      padding: 0.25rem 0.5rem;
      font-family: var(--nbg-ff-mono);
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--nbg-ink);
      text-decoration: none;
      border-radius: var(--nbg-r-sm);
      transition: background-color 150ms, color 150ms;
    }
    .glossary-letter:hover {
      background: var(--nbg-surface-2);
      color: var(--nbg-accent);
    }
    .glossary-letter[data-empty='true'] {
      opacity: 0.35;
      pointer-events: none;
    }
    .glossary-anchor {
      display: block;
      position: relative;
      top: -5rem;
      visibility: hidden;
    }
    .glossary-terms {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }
    .glossary-term {
      padding: 1.5rem;
      background: var(--nbg-surface);
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-lg);
      box-shadow: var(--nbg-shadow-md);
    }
    .glossary-term__head {
      display: flex;
      align-items: baseline;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }
    .glossary-term-link {
      color: inherit;
      text-decoration: none;
    }
    .glossary-term-link:hover {
      color: var(--nbg-accent);
    }
    .glossary-term-link:hover::after {
      content: ' #';
      color: var(--nbg-accent);
      font-family: var(--nbg-ff-mono);
      font-weight: 500;
    }
    .glossary-body {
      color: var(--nbg-ink-2);
      font-size: 0.9375rem;
      line-height: 1.6;
    }
    .glossary-body :global(p) {
      margin: 0 0 0.75rem;
    }
    .glossary-body :global(p:last-child) {
      margin-bottom: 0;
    }
    .glossary-term__footer {
      display: flex;
      justify-content: flex-end;
      margin-top: 1rem;
    }
    article[data-term][hidden] {
      display: none;
    }
  }
</style>

<script>
  import '../scripts/glossary-filter.ts';
</script>
