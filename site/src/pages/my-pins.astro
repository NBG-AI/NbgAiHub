---
// site/src/pages/my-pins.astro
//
// /my-pins/ — the per-user pinned-items dashboard (F-P11, project-design.md §P.4.4).
//
// Server-side render: two static panels (anonymous + signed-in skeleton) plus
// a loading state. The client `<script>` reads auth state, hydrates the
// signed-in panel by joining the user's gist favourites with the build-time
// pin indices (one /_data/<type>-index.json per type, emitted by
// scripts/build-pin-index.ts), and wires Unpin buttons through gist.ts.
//
// No raw fetch calls in this file — all gist + pin-index access is via the
// shared lib modules.
//
// Phase 6 / P4.H — Personalization Surfaces (Coder-H). Visual chrome migrated
// onto MarketingShell + primitives. The 14 data-* hooks, 2 ARIA-labelled
// section IDs, role="alert", and the entire <script> block are preserved
// bit-for-bit (AC23 + AC34). See project-design.md §S.13.10.10.

import MarketingShell from '../components/MarketingShell.astro';
import Stack from '../components/primitives/Stack.astro';
import Cluster from '../components/primitives/Cluster.astro';
import Card from '../components/primitives/Card.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import Display from '../components/primitives/Display.astro';
import Lede from '../components/primitives/Lede.astro';

// Pin-type label map — used by client JS via a JSON data island so we have
// one source of truth for type → display label.
const PIN_TYPE_LABELS = {
  skill: 'Skills',
  tip: 'Tips',
  news: 'News',
  'journey-step': 'Journey',
  glossary: 'Glossary',
} as const;
---

<MarketingShell
  title="My Pins"
  description="Your personal pinned-items dashboard. Pins live in your own GitHub gist (unlisted) — they are not shared with the team."
  surfaceId="my-pins"
  width="default"
>
  <Stack slot="hero" gap="4">
    <Eyebrow tone="accent">Personal</Eyebrow>
    <Display level={1} size="lg">My Pins</Display>
    <Lede size="lg">
      Your personal pinned-items dashboard. Pins live in your own GitHub gist
      (unlisted) — they are not shared with the team.
    </Lede>
  </Stack>

  <Stack gap="10">
    {/* Loading state — visible by default, hidden by the script once auth
        state is determined. Plain wrapper (no Section chrome) so [hidden]
        collapses the whole block to zero height; the .my-pins__loading[hidden]
        rule defeats the CSS display:flex specificity issue. */}
    <div class="my-pins__loading" data-my-pins-loading aria-busy="true">
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <p class="sr-only">Loading your pins…</p>
    </div>

    {/* Anonymous panel — shown when readToken() returns null. */}
    <section
      class="my-pins__anonymous"
      data-my-pins-anonymous
      hidden
      aria-labelledby="my-pins-anon-heading"
    >
      <Card variant="feature">
        <Stack gap="4">
          <Eyebrow tone="accent">Sign in</Eyebrow>
          <h2 id="my-pins-anon-heading" class="my-pins__anon-heading">
            Sign in to see your pins
          </h2>
          <Lede>
            Pinning is per-user and stored in a private gist on your GitHub
            account. Sign in to view, add, or remove pins.
          </Lede>
          <Cluster gap="3">
            <button
              type="button"
              class="my-pins__signin-btn"
              data-my-pins-signin
            >
              Sign in
            </button>
          </Cluster>
        </Stack>
      </Card>
    </section>

    {/* Signed-in panel — populated by the script. One unified grid of pin
        cards, with a filter chip row above that lights up only for types
        the user actually has pinned. */}
    <section
      class="my-pins__signed-in"
      data-my-pins-signed-in
      hidden
      aria-labelledby="my-pins-signed-in-heading"
    >
      <h2 id="my-pins-signed-in-heading" class="sr-only">Your pinned items</h2>

      <Stack gap="6">
        {/* Filter chip row — emitted by JS based on pin counts. Click a
            chip to filter the grid; the "All" chip is the default. */}
        <div class="my-pins__filters" data-my-pins-filters role="tablist" aria-label="Filter pins by type" hidden></div>

        {/* Empty state — friendly invite when the gist has zero favourites. */}
        <div data-my-pins-empty hidden class="my-pins__empty">
          <Stack gap="4">
            <p class="my-pins__empty-headline">
              You haven't pinned anything yet.
            </p>
            <p class="my-pins__empty-body">
              Click the pin button on any item across the site to save it here.
              A good place to start:
            </p>
            <Cluster gap="2">
              <a class="my-pins__empty-chip" href="/skills/">Skills</a>
              <a class="my-pins__empty-chip" href="/tips/">Tips</a>
              <a class="my-pins__empty-chip" href="/glossary/">Glossary</a>
            </Cluster>
          </Stack>
        </div>

        <p
          data-my-pins-error
          hidden
          class="my-pins__error"
          role="alert"
        ></p>

        {/* Unified pin grid — JS appends <li class="my-pins__card"> here. */}
        <ul class="my-pins__grid" data-pin-list aria-live="polite"></ul>
      </Stack>
    </section>

    {/* Privacy footer — single quiet line at the bottom of the page. */}
    <p class="my-pins__privacy" aria-label="Privacy">
      Pins live in your own unlisted GitHub gist — not shared with the team.
      <a
        href="https://github.com/settings/tokens"
        target="_blank"
        rel="noopener noreferrer"
      >Manage tokens</a> to revoke access.
    </p>
  </Stack>
</MarketingShell>

<script
  type="application/json"
  id="nbg-my-pins-type-labels"
  set:html={JSON.stringify(PIN_TYPE_LABELS)}
/>

<style is:global>
  /* `is:global` is load-bearing here — every selector in this block targets
     `.my-pins__*` (server-rendered shell + JS-created cards/chips). Without
     it, Astro adds `[data-astro-cid-…]` to each selector and the dynamic
     elements (built in the <script> below via document.createElement) miss
     the styles entirely. Namespace prefix keeps the global scope safe. */
  @layer nbg.components {
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* The Lede primitive ships with max-width: 56ch for readable measure on
       prose-heavy pages. On the my-pins surface we want the hero lede to span
       the full container width as a single line — scope the override via
       the [data-surface] attribute so other ledes elsewhere are untouched. */
    .nbg-marketing[data-surface='my-pins'] .nbg-lede {
      max-width: none;
    }

    /* Loading state — opacity-pulsing skeleton placeholders. The explicit
       [hidden] override is required because `display: flex` here would
       otherwise win specificity against the browser-default hidden rule. */
    .my-pins__loading {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding-block: 1.25rem 0.5rem;
    }
    .my-pins__loading[hidden] {
      display: none;
    }
    .my-pins__skeleton {
      display: block;
      height: 1rem;
      border-radius: var(--nbg-r-sm, 4px);
      background: var(--nbg-surface-2, var(--nbg-color-bg-elevated, #eef2f7));
      animation: nbg-skeleton-pulse 1.5s ease-in-out infinite;
    }
    .my-pins__skeleton:nth-child(1) { width: 38%; }
    .my-pins__skeleton:nth-child(2) { width: 52%; }
    .my-pins__skeleton:nth-child(3) { width: 30%; }

    @keyframes nbg-skeleton-pulse {
      0%, 100% { opacity: 0.45; }
      50%      { opacity: 0.85; }
    }
    @media (prefers-reduced-motion: reduce) {
      .my-pins__skeleton { animation: none; opacity: 0.65; }
    }

    /* Anonymous-state heading — mirrors Display level=2 size=sm look, but is
       a real <h2 id> so the surrounding section can use aria-labelledby
       without a Display-primitive prop forwarding change. */
    .my-pins__anon-heading {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-display-sm);
      font-weight: var(--nbg-fw-bold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-display);
      color: var(--nbg-color-fg-primary);
      font-variation-settings: 'opsz' var(--nbg-opsz-display);
      text-wrap: balance;
    }

    /* Group heading — single quiet mono eyebrow label. The previous design
       paired an Eyebrow primitive ABOVE a serif h3 with the same text, which
       read as duplication. One label per group: small, mono, all-caps. */
    .my-pins__group-heading {
      margin: 0;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--nbg-muted, var(--nbg-color-fg-muted, #5b6478));
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--nbg-hairline, var(--nbg-color-border-subtle, #e1e6ed));
    }

    /* Anonymous-state sign-in button — token-driven primary CTA. Plain
       <button> rather than the Button primitive because the script reads
       its `data-my-pins-signin` attribute via querySelector. */
    .my-pins__signin-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--nbg-sp-2);
      padding: var(--nbg-sp-3) var(--nbg-sp-6);
      border: 1px solid var(--nbg-color-accent-strong);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-accent-strong);
      color: var(--nbg-color-fg-on-accent);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-lg);
      font-weight: var(--nbg-fw-semibold);
      letter-spacing: var(--nbg-ls-normal);
      line-height: 1;
      cursor: pointer;
      user-select: none;
      transition: background-color var(--nbg-dur-fast) var(--nbg-ease-out),
                  border-color     var(--nbg-dur-fast) var(--nbg-ease-out),
                  transform        var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .my-pins__signin-btn:hover {
      background: var(--nbg-color-accent-hover);
      border-color: var(--nbg-color-accent-hover);
      transform: translateY(-1px);
    }
    .my-pins__signin-btn:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* ── Filter chips ──────────────────────────────────────────────── */
    .my-pins__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }
    .my-pins__filters[hidden] { display: none; }
    .my-pins__filter-chip {
      /* Explicit height guarantees every chip renders identically regardless
         of its inner content (label-only vs label+count bubble).
         margin: 0 defeats Starlight's `.sl-markdown-content` vertical-rhythm
         rule (`:not(a,...) + :not(a,...) { margin-top: 1rem }`) which
         otherwise adds 16px to every chip after the first, breaking the row
         alignment. Same pattern as the homepage `.router-grid` fix per
         DECISIONS 2026-05-25. */
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      height: 2.25rem;
      margin: 0;
      padding: 0 0.95rem;
      border-radius: 999px;
      border: 1px solid color-mix(in srgb, var(--nbg-ink, #1a2030) 14%, transparent);
      background: var(--nbg-bg, #fff);
      color: var(--nbg-ink-2, #4a5563);
      font-family: var(--nbg-ff-body);
      font-size: 0.8125rem;
      font-weight: 500;
      line-height: 1;
      cursor: pointer;
      box-sizing: border-box;
      transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
    }
    .my-pins__filter-chip:hover {
      background: var(--nbg-surface-2, #eef2f7);
      border-color: color-mix(in srgb, var(--nbg-ink, #1a2030) 30%, transparent);
      color: var(--nbg-ink, #1a2030);
    }
    .my-pins__filter-chip[aria-pressed='true'] {
      background: var(--nbg-ink, #1a2030);
      border-color: var(--nbg-ink, #1a2030);
      color: var(--nbg-bg, #fff);
    }
    /* Count badge — sits inside the chip on its own small bubble. Sized so
       it fits comfortably within the chip's fixed 2.25rem height. */
    .my-pins__filter-chip__count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.375rem;
      height: 1.375rem;
      padding: 0 0.4rem;
      border-radius: 999px;
      background: color-mix(in srgb, var(--nbg-ink, #1a2030) 8%, transparent);
      color: inherit;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 500;
      line-height: 1;
      box-sizing: border-box;
    }
    .my-pins__filter-chip[aria-pressed='true'] .my-pins__filter-chip__count {
      background: color-mix(in srgb, var(--nbg-bg, #fff) 20%, transparent);
    }

    /* ── Pin grid ──────────────────────────────────────────────────── */
    .my-pins__grid {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
      gap: 0.875rem;
    }

    /* ── Pin card ──────────────────────────────────────────────────── */
    .my-pins__card {
      /* margin: 0 defeats Starlight's `.sl-markdown-content` sibling-margin
         rule which would otherwise add 16px to every card after the first
         and break the grid's symmetric gap. Same fix as the filter chips. */
      position: relative;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
      padding: 1.25rem 1.375rem;
      border: 1px solid color-mix(in srgb, var(--nbg-ink, #1a2030) 14%, transparent);
      border-radius: 12px;
      background: var(--nbg-bg, #fff);
      box-shadow: 0 1px 2px 0 color-mix(in srgb, var(--nbg-ink, #1a2030) 5%, transparent);
      transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
    }
    .my-pins__card:hover {
      border-color: color-mix(in srgb, var(--nbg-accent, #0a8a7d) 55%, transparent);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px -12px color-mix(in srgb, var(--nbg-ink, #1a2030) 22%, transparent);
    }
    .my-pins__card[data-pin-hidden='true'] {
      display: none;
    }
    .my-pins__card.my-pins__stale {
      opacity: 0.55;
      font-style: italic;
    }

    .my-pins__card-type {
      display: inline-flex;
      align-self: flex-start;
      align-items: center;
      padding: 2px 8px;
      border-radius: 999px;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.625rem;
      font-weight: 500;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      background: color-mix(in srgb, var(--nbg-accent, #0a8a7d) 12%, transparent);
      color: var(--nbg-accent, #0a8a7d);
      border: 1px solid color-mix(in srgb, var(--nbg-accent, #0a8a7d) 25%, transparent);
      line-height: 1.4;
    }

    .my-pins__card-title {
      margin: 0;
      font-family: var(--nbg-ff-body);
      font-size: 1rem;
      font-weight: 500;
      line-height: 1.35;
      color: var(--nbg-ink, #1a2030);
      letter-spacing: -0.005em;
      /* Right-pad so the title never collides with the absolute-positioned × button. */
      padding-right: 2rem;
      overflow-wrap: anywhere;
    }
    .my-pins__card-title a {
      color: inherit;
      text-decoration: none;
      background-image: linear-gradient(to right, var(--nbg-accent, #0a8a7d), var(--nbg-accent, #0a8a7d));
      background-size: 0 1px;
      background-repeat: no-repeat;
      background-position: 0 100%;
      transition: background-size 200ms ease, color 120ms ease;
    }
    .my-pins__card-title a:hover {
      color: var(--nbg-accent, #0a8a7d);
      background-size: 100% 1px;
    }

    .my-pins__card-meta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.625rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--nbg-muted, #6b7280);
      margin-top: auto; /* pin meta to card bottom */
    }
    .my-pins__card-audience--beginner { color: var(--nbg-accent, #0a8a7d); }
    .my-pins__card-audience--advanced { color: var(--nbg-ink, #1a2030); }

    /* × unpin button, top-right corner */
    .my-pins__card-unpin {
      position: absolute;
      top: 0.5rem;
      right: 0.5rem;
      width: 1.75rem;
      height: 1.75rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      border: 1px solid transparent;
      background: transparent;
      border-radius: 999px;
      color: var(--nbg-muted, #6b7280);
      font-size: 1.1rem;
      line-height: 1;
      cursor: pointer;
      opacity: 0;
      transition: opacity 140ms ease, background-color 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .my-pins__card:hover .my-pins__card-unpin,
    .my-pins__card-unpin:focus-visible {
      opacity: 1;
    }
    .my-pins__card-unpin:hover {
      background: var(--nbg-surface-2, #eef2f7);
      border-color: var(--nbg-hairline, #d8dde5);
      color: var(--nbg-ink, #1a2030);
    }
    .my-pins__card-unpin:focus-visible {
      outline: 2px solid var(--nbg-accent, #0a8a7d);
      outline-offset: 2px;
    }
    .my-pins__card-unpin[disabled] {
      opacity: 0.5;
      cursor: progress;
    }

    /* ── Empty / error / privacy ───────────────────────────────────── */
    .my-pins__empty {
      padding: 2rem 1.75rem;
      border: 1px dashed var(--nbg-hairline, #d8dde5);
      border-radius: 12px;
      background: var(--nbg-surface-2, color-mix(in srgb, var(--nbg-bg, #fff) 92%, var(--nbg-ink, #1a2030)));
    }
    .my-pins__empty-headline {
      margin: 0;
      font-family: var(--nbg-ff-serif, Georgia, serif);
      font-size: 1.25rem;
      font-weight: 500;
      color: var(--nbg-ink, #1a2030);
      letter-spacing: -0.01em;
    }
    .my-pins__empty-body {
      margin: 0;
      color: var(--nbg-ink-2, #4a5563);
      line-height: 1.55;
    }
    .my-pins__empty-chip {
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.85rem;
      border-radius: 999px;
      border: 1px solid var(--nbg-hairline, #e1e6ed);
      background: var(--nbg-bg, #fff);
      color: var(--nbg-ink, #1a2030);
      font-size: 0.8125rem;
      font-weight: 500;
      text-decoration: none;
      transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
    }
    .my-pins__empty-chip:hover {
      background: var(--nbg-ink, #1a2030);
      border-color: var(--nbg-ink, #1a2030);
      color: var(--nbg-bg, #fff);
    }

    .my-pins__error {
      padding: 0.75rem 1rem;
      border-radius: 8px;
      background: color-mix(in srgb, #dc2626 8%, transparent);
      color: #b91c1c;
      border: 1px solid color-mix(in srgb, #dc2626 25%, transparent);
      margin: 0;
      font-size: 0.9rem;
    }

    .my-pins__privacy {
      margin: 1rem 0 0;
      padding-top: 1.5rem;
      border-top: 1px solid var(--nbg-hairline, #e1e6ed);
      font-size: 0.8125rem;
      color: var(--nbg-muted, #6b7280);
      line-height: 1.6;
    }
    .my-pins__privacy a {
      color: var(--nbg-accent, #0a8a7d);
      text-decoration: none;
      border-bottom: 1px solid color-mix(in srgb, var(--nbg-accent, #0a8a7d) 40%, transparent);
      padding-bottom: 1px;
    }
    .my-pins__privacy a:hover {
      border-bottom-color: var(--nbg-accent, #0a8a7d);
    }
  }
</style>

<script>
  import { readToken, subscribe } from '../lib/auth.ts';
  import { findOrCreateFavoritesGist, removeFavorite } from '../lib/gist.ts';
  import {
    fetchAllPinIndices,
    joinFavoritesWithIndex,
    groupFavoritesByType,
    type HydratedPin,
  } from '../lib/pin-store.ts';

  type PinType = 'skill' | 'tip' | 'news' | 'journey-step' | 'glossary';

  /** Map (type, slug) -> on-site URL for the title link. Best-effort. */
  function urlForPin(type: PinType, slug: string): string {
    switch (type) {
      case 'news':
        return `/news/${slug}/`;
      case 'skill':
        return `/skills/`;
      case 'tip':
        return `/tips/`;
      case 'glossary':
        return `/glossary#${slug}`;
      case 'journey-step':
        return `/start-here/${slug}/`;
    }
  }

  function getLoading(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-loading]');
  }
  function getAnonymous(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-anonymous]');
  }
  function getSignedIn(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-signed-in]');
  }
  function getEmpty(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-empty]');
  }
  function getErrorBox(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-error]');
  }

  function show(el: HTMLElement | null): void {
    if (el !== null) el.hidden = false;
  }
  function hide(el: HTMLElement | null): void {
    if (el !== null) el.hidden = true;
  }

  function setError(message: string | null): void {
    const box = getErrorBox();
    if (box === null) return;
    if (message === null) {
      box.textContent = '';
      box.hidden = true;
    } else {
      box.textContent = message;
      box.hidden = false;
    }
  }

  function getGrid(): HTMLUListElement | null {
    return document.querySelector<HTMLUListElement>('ul[data-pin-list]');
  }
  function getFiltersBox(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-filters]');
  }

  function clearGridAndFilters(): void {
    const grid = getGrid();
    if (grid !== null) grid.replaceChildren();
    const filters = getFiltersBox();
    if (filters !== null) {
      filters.replaceChildren();
      filters.hidden = true;
    }
  }

  function readTypeLabels(): Record<string, string> {
    const node = document.getElementById('nbg-my-pins-type-labels');
    if (node === null) return {};
    try {
      return JSON.parse(node.textContent ?? '{}') as Record<string, string>;
    } catch {
      return {};
    }
  }
  const TYPE_LABELS = readTypeLabels();
  function labelForType(type: string): string {
    return TYPE_LABELS[type] ?? type;
  }

  function readAuthState(): { token: string } | null {
    try {
      return readToken();
    } catch {
      return null;
    }
  }

  function showAnonymousPanel(): void {
    hide(getLoading());
    hide(getSignedIn());
    show(getAnonymous());
  }

  function showLoadingState(): void {
    show(getLoading());
    hide(getAnonymous());
    hide(getSignedIn());
  }

  function showSignedInPanel(): void {
    hide(getLoading());
    hide(getAnonymous());
    show(getSignedIn());
  }

  function buildPinCard(
    pin: HydratedPin,
    onUnpin: (pin: HydratedPin, card: HTMLLIElement) => void,
  ): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'my-pins__card';
    li.dataset.pinSlug = pin.slug;
    li.dataset.pinType = pin.type;

    // Type chip — quiet mono accent pill, top-left of the card.
    const typeChip = document.createElement('span');
    typeChip.className = 'my-pins__card-type';
    typeChip.textContent = labelForType(pin.type);
    li.appendChild(typeChip);

    // Title (the link). When the item is no longer in the index we render
    // a non-link stale message instead — same as the previous behaviour.
    const title = document.createElement('h3');
    title.className = 'my-pins__card-title';
    if (pin.display !== null) {
      const a = document.createElement('a');
      a.href = urlForPin(pin.type as PinType, pin.slug);
      a.textContent = pin.display.title;
      title.appendChild(a);
    } else {
      li.classList.add('my-pins__stale');
      title.textContent = `No longer available (${pin.type}/${pin.slug})`;
    }
    li.appendChild(title);

    // Footer meta line — audience tag pushed to card bottom via margin-top:auto.
    if (pin.display !== null) {
      const meta = document.createElement('div');
      meta.className = 'my-pins__card-meta';
      const audience = document.createElement('span');
      audience.className = `my-pins__card-audience my-pins__card-audience--${pin.display.audience}`;
      audience.textContent = pin.display.audience;
      meta.appendChild(audience);
      li.appendChild(meta);
    }

    // × unpin — fades in on hover or focus, top-right corner.
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'my-pins__card-unpin';
    btn.textContent = '×';
    btn.setAttribute('aria-label', `Unpin ${pin.display?.title ?? pin.slug}`);
    btn.addEventListener('click', () => onUnpin(pin, li));
    li.appendChild(btn);

    return li;
  }

  /** Build the filter chip row. Only emits chips for types that have ≥1 pin. */
  function buildFilters(grouped: Record<PinType, HydratedPin[]>, totalCount: number): void {
    const box = getFiltersBox();
    if (box === null) return;
    box.replaceChildren();

    const onChipClick = (filterType: PinType | 'all', clicked: HTMLButtonElement): void => {
      const allChips = box.querySelectorAll<HTMLButtonElement>('.my-pins__filter-chip');
      allChips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      clicked.setAttribute('aria-pressed', 'true');
      const cards = document.querySelectorAll<HTMLLIElement>('.my-pins__card');
      cards.forEach((card) => {
        const show = filterType === 'all' || card.dataset.pinType === filterType;
        card.dataset.pinHidden = show ? 'false' : 'true';
      });
    };

    const makeChip = (filterType: PinType | 'all', label: string, count: number, pressed: boolean): HTMLButtonElement => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'my-pins__filter-chip';
      chip.setAttribute('role', 'tab');
      chip.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      chip.dataset.filter = filterType;
      const labelSpan = document.createElement('span');
      labelSpan.textContent = label;
      const countSpan = document.createElement('span');
      countSpan.className = 'my-pins__filter-chip__count';
      countSpan.textContent = String(count);
      chip.appendChild(labelSpan);
      chip.appendChild(countSpan);
      chip.addEventListener('click', () => onChipClick(filterType, chip));
      return chip;
    };

    box.appendChild(makeChip('all', 'All', totalCount, true));
    (['skill', 'tip', 'news', 'journey-step', 'glossary'] as const).forEach((t) => {
      const count = grouped[t].length;
      if (count > 0) box.appendChild(makeChip(t, labelForType(t), count, false));
    });
    box.hidden = false;
  }

  async function renderSignedIn(token: string): Promise<void> {
    showLoadingState();
    setError(null);
    clearGridAndFilters();
    hide(getEmpty());

    let gistId: string;
    let favourites: HydratedPin[] = [];
    try {
      const gistResult = await findOrCreateFavoritesGist(token);
      gistId = gistResult.gistId;
      const indices = await fetchAllPinIndices();
      favourites = joinFavoritesWithIndex(gistResult.document.favourites, indices);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      showSignedInPanel();
      setError(`Could not load your pins: ${msg}`);
      show(getEmpty());
      return;
    }

    const grouped = groupFavoritesByType(favourites);

    if (favourites.length === 0) {
      showSignedInPanel();
      show(getEmpty());
      return;
    }

    const grid = getGrid();
    if (grid === null) {
      showSignedInPanel();
      return;
    }

    const onUnpin = async (pin: HydratedPin, card: HTMLLIElement): Promise<void> => {
      const btn = card.querySelector<HTMLButtonElement>('.my-pins__card-unpin');
      const parent = card.parentElement;
      const nextSibling = card.nextSibling;
      if (btn !== null) btn.disabled = true;
      // Optimistic removal.
      card.remove();
      try {
        await removeFavorite(token, gistId, { type: pin.type, slug: pin.slug });
        // Refresh filter chips so the count + type chip removal stays accurate.
        const anyLeft = grid.querySelector<HTMLLIElement>('.my-pins__card');
        if (anyLeft === null) {
          const filters = getFiltersBox();
          if (filters !== null) { filters.replaceChildren(); filters.hidden = true; }
          show(getEmpty());
        } else {
          // Rebuild chips from remaining cards.
          const remaining: HydratedPin[] = Array.from(
            grid.querySelectorAll<HTMLLIElement>('.my-pins__card'),
          ).map((c) => ({
            slug: c.dataset.pinSlug ?? '',
            type: (c.dataset.pinType ?? 'skill') as PinType,
            display: null,
          })) as unknown as HydratedPin[];
          buildFilters(groupFavoritesByType(remaining), remaining.length);
        }
      } catch (err) {
        if (parent !== null) parent.insertBefore(card, nextSibling);
        if (btn !== null) btn.disabled = false;
        const msg = err instanceof Error ? err.message : String(err);
        setError(`Could not unpin: ${msg}`);
      }
    };

    // Build the grid in F-P11 display order (skill → tip → news → journey → glossary).
    (['skill', 'tip', 'news', 'journey-step', 'glossary'] as const).forEach((type) => {
      for (const pin of grouped[type]) {
        grid.appendChild(buildPinCard(pin, onUnpin));
      }
    });

    buildFilters(grouped, favourites.length);
    showSignedInPanel();
  }

  function wireSignInButton(): void {
    const btn = document.querySelector<HTMLButtonElement>('[data-my-pins-signin]');
    if (btn === null) return;
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('nbgaihub:open-signin-modal'));
    });
  }

  async function render(): Promise<void> {
    const state = readAuthState();
    if (state === null) {
      showAnonymousPanel();
      return;
    }
    await renderSignedIn(state.token);
  }

  function init(): void {
    wireSignInButton();
    void render();

    subscribe((authState) => {
      if (authState === 'signed-out') {
        showAnonymousPanel();
      } else {
        void render();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
