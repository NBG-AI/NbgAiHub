---
// site/src/pages/my-pins.astro
//
// /my-pins/ — the per-user pinned-items dashboard (F-P11, project-design.md §P.4.4).
//
// Server-side render: two static panels (anonymous + signed-in skeleton) plus
// a loading state. The client `<script>` reads auth state, hydrates the
// signed-in panel by joining the user's gist favourites with the build-time
// pin indices (one /_data/<type>-index.json per type, emitted by
// scripts/build-pin-index.ts), and wires Unpin buttons through gist.ts.
//
// No raw fetch calls in this file — all gist + pin-index access is via the
// shared lib modules.
//
// Phase 6 / P4.H — Personalization Surfaces (Coder-H). Visual chrome migrated
// onto MarketingShell + primitives. The 14 data-* hooks, 2 ARIA-labelled
// section IDs, role="alert", and the entire <script> block are preserved
// bit-for-bit (AC23 + AC34). See project-design.md §S.13.10.10.

import MarketingShell from '../components/MarketingShell.astro';

// Pin-type label map — used by client JS via a JSON data island so we have
// one source of truth for type → display label.
const PIN_TYPE_LABELS = {
  skill: 'Skills',
  tip: 'Tips',
  'use-case': 'Use cases',
  news: 'News',
  'journey-step': 'Journey',
  glossary: 'Glossary',
} as const;
---

<MarketingShell
  title="My Pins"
  description="Your personal pinned-items dashboard. Pins live in your own GitHub gist (unlisted) — they are not shared with the team."
  surfaceId="my-pins"
  width="full"
  hero="none"
>
  {/* 2026-05-25 — hero matches /start-here/foundations/ (UAT image #17):
      `.hero hero--stack` is the full-width single-column hero used by the
      reader-mode marketing pages. Larger serif title, lede directly below,
      no 2-column split. */}
  <section class="hero hero--stack">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">My <em>Pins</em></h1>
        <p class="hero__lede">
          Your personal pinned-items dashboard. Pins live in your own GitHub
          gist (unlisted) — they are not shared with the team.
        </p>
      </div>
    </div>
  </section>

  {/* No `.section` wrapper — that class injects 3.5rem padding-block which
      created the gigantic empty gap UAT image #18 flagged. Plain wrapper. */}
  <div class="my-pins__body">
    <div class="wrap" style="display: grid; gap: 1.5rem;">
    {/* Loading state — visible by default, hidden by the script once auth
        state is determined. Plain wrapper (no Section chrome) so [hidden]
        collapses the whole block to zero height; the .my-pins__loading[hidden]
        rule defeats the CSS display:flex specificity issue. */}
    <div class="my-pins__loading" data-my-pins-loading aria-busy="true">
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <span class="my-pins__skeleton" aria-hidden="true"></span>
      <p class="sr-only">Loading your pins…</p>
    </div>

    {/* Anonymous panel — 2-column layout (UAT image #18 redesign):
        LEFT  = headline, lede, primary CTA, "no account?" footnote
        RIGHT = four FAQ mini-cards with numeric markers
        Single-column on narrow viewports. */}
    <section
      class="my-pins__anonymous"
      data-my-pins-anonymous
      hidden
      aria-labelledby="my-pins-anon-heading"
    >
      {/* Rejection banner — only visible when the previous session ended
          because GitHub rejected the stored token (TokenInvalidError). The
          script flips it on by reading auth.wasTokenRejected(). Reading
          this is what turns "the site forgot me" into a clear next step. */}
      <div
        class="my-pins__rejection-banner"
        data-my-pins-rejection-banner
        role="status"
        hidden
      >
        <div class="my-pins__rejection-body">
          <p class="my-pins__rejection-headline">
            Your previous token was rejected by GitHub — most likely it expired.
          </p>
          <p class="my-pins__rejection-lede">
            GitHub personal access tokens expire by default. Generate a new
            one and pick <strong>“No expiration”</strong> this time so you
            don’t have to do this again.
          </p>
        </div>
        <div class="my-pins__rejection-actions">
          <button
            type="button"
            class="my-pins__rejection-signin"
            data-my-pins-rejection-signin
          >
            Sign in again
          </button>
          <button
            type="button"
            class="my-pins__rejection-dismiss"
            data-my-pins-rejection-dismiss
            aria-label="Dismiss this notice"
          >
            Dismiss
          </button>
        </div>
      </div>

      <div class="my-pins__anon-grid">
        <div class="my-pins__anon-main">
          <span class="my-pins__anon-eyebrow">Sign in</span>
          <h2 id="my-pins-anon-heading" class="my-pins__anon-heading">
            Sign in to see your pins
          </h2>
          <p class="my-pins__anon-lede">
            Pinning is per-user and lives in your own private GitHub gist —
            never on our server, never shared with the team.
          </p>
          <button
            type="button"
            class="my-pins__signin-btn"
            data-my-pins-signin
          >
            Sign in with a GitHub PAT
          </button>
          <p class="my-pins__anon-foot">
            No GitHub account? Pinning is optional — you can browse,
            search, and read everything on the site without signing in.
          </p>
        </div>

        <aside class="my-pins__anon-faq" aria-labelledby="my-pins-faq-heading">
          <h3 id="my-pins-faq-heading" class="my-pins__anon-faq-heading">
            First time? Here's what's going on
          </h3>
          <div class="my-pins__faq-list">
            <div class="my-pins__faq-item">
              <span class="my-pins__faq-num" aria-hidden="true">01</span>
              <div class="my-pins__faq-body">
                <h4>What's a PAT?</h4>
                <p>
                  A <strong>Personal Access Token</strong> — a long string
                  that lets a site act on your behalf without your password.
                  Like an app-specific password you can revoke any time.
                </p>
              </div>
            </div>
            <div class="my-pins__faq-item">
              <span class="my-pins__faq-num" aria-hidden="true">02</span>
              <div class="my-pins__faq-body">
                <h4>Why does this site need one?</h4>
                <p>
                  So your pins live in <em>your own</em> gist — not on our
                  server. Nothing about you is stored centrally.
                </p>
              </div>
            </div>
            <div class="my-pins__faq-item">
              <span class="my-pins__faq-num" aria-hidden="true">03</span>
              <div class="my-pins__faq-body">
                <h4>Is it safe?</h4>
                <p>
                  Token is scoped to <code>gist</code> only — it can't see
                  your code, repos, or settings. Revoke any time at
                  <a
                    href="https://github.com/settings/tokens"
                    target="_blank"
                    rel="noopener noreferrer"
                  >github.com/settings/tokens</a>.
                </p>
              </div>
            </div>
            <div class="my-pins__faq-item">
              <span class="my-pins__faq-num" aria-hidden="true">04</span>
              <div class="my-pins__faq-body">
                <h4>Where does it live?</h4>
                <p>
                  In your browser's local storage. It never leaves your
                  machine except when the site talks to GitHub's API.
                </p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    {/* Signed-in panel — populated by the script. One unified grid of pin
        cards, with a filter chip row above that lights up only for types
        the user actually has pinned. */}
    <section
      class="my-pins__signed-in"
      data-my-pins-signed-in
      hidden
      aria-labelledby="my-pins-signed-in-heading"
    >
      <h2 id="my-pins-signed-in-heading" class="sr-only">Your pinned items</h2>

      <div style="display: grid; gap: 1.5rem;">
        {/* Library header strip — sits directly under the hero so the page
            doesn't dump filter chips into empty space. Two-row layout:
            eyebrow + count summary on the left, filter chips on the right
            (wraps below on narrow viewports). */}
        <div class="my-pins__library-header" data-my-pins-library-header hidden>
          <div class="my-pins__library-intro">
            <p class="my-pins__library-eyebrow">Your library</p>
            <p class="my-pins__library-stats" data-my-pins-stats></p>
          </div>
          {/* Filter chip row — emitted by JS based on pin counts. */}
          <div class="my-pins__filters" data-my-pins-filters role="tablist" aria-label="Filter pins by type" hidden></div>
        </div>

        {/* Empty state — friendly invite when the gist has zero favourites. */}
        <div data-my-pins-empty hidden class="my-pins__empty">
          <p class="my-pins__empty-headline">
            You haven't pinned anything yet.
          </p>
          <p class="my-pins__empty-body">
            Click the pin button on any item across the site to save it here.
            A good place to start:
          </p>
          <div class="my-pins__empty-chips">
            <a class="my-pins__empty-chip" href="/skills/">Skills</a>
            <a class="my-pins__empty-chip" href="/tips/">Tips</a>
            <a class="my-pins__empty-chip" href="/glossary/">Glossary</a>
          </div>
        </div>

        <p
          data-my-pins-error
          hidden
          class="my-pins__error"
          role="alert"
        ></p>

        {/* Unified pin grid — JS appends <li class="my-pins__card"> here. */}
        <ul class="my-pins__grid" data-pin-list aria-live="polite"></ul>
      </div>
    </section>

    {/* Privacy footer — single quiet line at the bottom of the page. */}
    <p class="my-pins__privacy" aria-label="Privacy">
      Pins live in your own unlisted GitHub gist — not shared with the team.
      <a
        href="https://github.com/settings/tokens"
        target="_blank"
        rel="noopener noreferrer"
      >Manage tokens</a> to revoke access.
    </p>
    </div>
  </div>
</MarketingShell>

<script
  type="application/json"
  id="nbg-my-pins-type-labels"
  set:html={JSON.stringify(PIN_TYPE_LABELS)}
/>

<style is:global>
  /* `is:global` is load-bearing here — every selector in this block targets
     `.my-pins__*` (server-rendered shell + JS-created cards/chips). Without
     it, Astro adds `[data-astro-cid-…]` to each selector and the dynamic
     elements (built in the <script> below via document.createElement) miss
     the styles entirely. Namespace prefix keeps the global scope safe. */
  @layer nbg.components {
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* The Lede primitive ships with max-width: 56ch for readable measure on
       prose-heavy pages. On the my-pins surface we want the hero lede to span
       the full container width as a single line — scope the override via
       the [data-surface] attribute so other ledes elsewhere are untouched. */
    .nbg-marketing[data-surface='my-pins'] .nbg-lede {
      max-width: none;
    }

    /* Loading state — opacity-pulsing skeleton placeholders. The explicit
       [hidden] override is required because `display: flex` here would
       otherwise win specificity against the browser-default hidden rule. */
    .my-pins__loading {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding-block: 1.25rem 0.5rem;
    }
    .my-pins__loading[hidden] {
      display: none;
    }
    .my-pins__skeleton {
      display: block;
      height: 1rem;
      border-radius: var(--nbg-r-sm, 4px);
      background: var(--nbg-surface-2, var(--nbg-color-bg-elevated, #eef2f7));
      animation: nbg-skeleton-pulse 1.5s ease-in-out infinite;
    }
    .my-pins__skeleton:nth-child(1) { width: 38%; }
    .my-pins__skeleton:nth-child(2) { width: 52%; }
    .my-pins__skeleton:nth-child(3) { width: 30%; }

    @keyframes nbg-skeleton-pulse {
      0%, 100% { opacity: 0.45; }
      50%      { opacity: 0.85; }
    }
    @media (prefers-reduced-motion: reduce) {
      .my-pins__skeleton { animation: none; opacity: 0.65; }
    }

    /* Body wrapper — keep the hero→content gap tight. The hero already
       carries its own bottom padding, so 0.5rem here is enough breath.
       Bottom keeps a generous 4rem so the privacy footer doesn't crowd
       the last card. */
    .my-pins__body {
      padding-block: 0.5rem 4rem;
    }
    /* Reader-mode .hero ships with a heavy bottom padding (+ hairline
       border on some surfaces) intended for prose pages. On /my-pins the
       hero is just a name + lede, so we tighten the gap into the library
       header. Matches the same compaction trick listing pages use. */
    .nbg-marketing[data-surface='my-pins'] .hero--stack {
      padding-bottom: 0.75rem !important;
      border-bottom: 0 !important;
    }

    /* ── Library header strip ─────────────────────────────────────────
       Top-of-content band that gives the page a clear "library" identity
       and a count summary instead of orphaned filter chips floating in
       whitespace. Left column: eyebrow + stats. Right column: filter
       chips. Stacks vertically below 720px. */
    .my-pins__library-header {
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      justify-content: space-between;
      gap: 1.25rem 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid var(--nbg-hairline, #e1e6ed);
    }
    .my-pins__library-header[hidden] { display: none; }
    .my-pins__library-intro {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      min-width: 0;
    }
    .my-pins__library-eyebrow {
      margin: 0;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--nbg-accent, #0a8a7d);
    }
    .my-pins__library-stats {
      margin: 0;
      font-family: var(--nbg-ff-serif, 'Newsreader', Georgia, serif);
      font-size: 1.15rem;
      font-weight: 500;
      line-height: 1.3;
      letter-spacing: -0.012em;
      color: var(--nbg-ink, #1a2030);
    }
    @media (max-width: 720px) {
      .my-pins__library-header {
        align-items: stretch;
        gap: 0.85rem;
      }
    }

    /* Token-rejection banner — only renders when the user landed here
       because GitHub rejected their stored PAT. Amber-tinted "soft warning"
       palette so it reads as informative rather than alarming. Tells the
       user exactly why they got logged out + what to pick this time. */
    .my-pins__rejection-banner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 1.5rem;
      padding: 1.1rem 1.35rem;
      margin-bottom: 1.5rem;
      border: 1px solid color-mix(in srgb, #b45309 35%, transparent);
      border-radius: var(--nbg-r-lg, 12px);
      background: color-mix(in srgb, #fef3c7 60%, var(--nbg-bg, #fff));
      color: var(--nbg-ink, #1a2030);
    }
    .my-pins__rejection-banner[hidden] { display: none; }
    @media (max-width: 720px) {
      .my-pins__rejection-banner {
        grid-template-columns: 1fr;
        gap: 0.85rem;
      }
    }
    .my-pins__rejection-body {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      min-width: 0;
    }
    .my-pins__rejection-headline {
      margin: 0;
      font-family: var(--nbg-ff-body);
      font-size: 0.9375rem;
      font-weight: 600;
      color: #78350f;
      line-height: 1.35;
    }
    .my-pins__rejection-lede {
      margin: 0;
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--nbg-ink-2, #4a5563);
    }
    .my-pins__rejection-lede strong {
      color: var(--nbg-ink, #1a2030);
      font-weight: 600;
    }
    .my-pins__rejection-actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-shrink: 0;
    }
    .my-pins__rejection-signin {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem 0.95rem;
      border-radius: var(--nbg-r-md, 8px);
      border: 1px solid var(--nbg-color-accent-strong, #0a8a7d);
      background: var(--nbg-color-accent-strong, #0a8a7d);
      color: var(--nbg-color-fg-on-accent, #fff);
      font-family: var(--nbg-ff-body);
      font-size: 0.875rem;
      font-weight: 600;
      line-height: 1;
      cursor: pointer;
      transition: background-color 140ms ease, border-color 140ms ease, transform 140ms ease;
    }
    .my-pins__rejection-signin:hover {
      background: var(--nbg-color-accent-hover, #00525c);
      border-color: var(--nbg-color-accent-hover, #00525c);
      transform: translateY(-1px);
    }
    .my-pins__rejection-signin:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
    .my-pins__rejection-dismiss {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.55rem 0.85rem;
      border-radius: var(--nbg-r-md, 8px);
      border: 1px solid transparent;
      background: transparent;
      color: var(--nbg-muted, #6b7280);
      font-family: var(--nbg-ff-body);
      font-size: 0.875rem;
      font-weight: 500;
      line-height: 1;
      cursor: pointer;
      transition: background-color 140ms ease, color 140ms ease, border-color 140ms ease;
    }
    .my-pins__rejection-dismiss:hover {
      background: var(--nbg-surface-2, #f3f4f6);
      color: var(--nbg-ink, #1a2030);
      border-color: var(--nbg-hairline, #e1e6ed);
    }
    .my-pins__rejection-dismiss:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* 2-column anonymous card: CTA panel on the left, FAQ aside on the
       right. Single column under 880px. */
    .my-pins__anon-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
      gap: 2rem;
      align-items: stretch;
      padding: 2.25rem;
      border: 1px solid var(--nbg-hairline, #e1e6ed);
      border-radius: var(--nbg-r-lg, 12px);
      background: var(--nbg-bg, #fff);
      box-shadow: 0 1px 2px rgba(10, 20, 40, 0.02);
    }
    @media (max-width: 880px) {
      .my-pins__anon-grid { grid-template-columns: 1fr; padding: 1.5rem; }
    }

    /* LEFT — primary CTA panel */
    .my-pins__anon-main {
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      padding-right: 0.5rem;
    }
    .my-pins__anon-eyebrow {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--nbg-accent, #0a8a7d);
    }
    .my-pins__anon-heading {
      margin: 0;
      font-family: var(--nbg-ff-serif, Georgia, serif);
      font-size: clamp(1.4rem, 2vw, 1.75rem);
      font-weight: 500;
      line-height: 1.2;
      letter-spacing: -0.015em;
      color: var(--nbg-ink, #1a2030);
      text-wrap: balance;
    }
    .my-pins__anon-lede {
      margin: 0;
      font-size: 0.9375rem;
      line-height: 1.55;
      color: var(--nbg-muted, #6b7280);
    }
    .my-pins__anon-foot {
      margin: 0;
      padding-top: 1rem;
      border-top: 1px solid var(--nbg-hairline, #e1e6ed);
      font-size: 0.8125rem;
      line-height: 1.55;
      color: var(--nbg-muted, #6b7280);
    }

    /* RIGHT — FAQ mini-cards. Numeric markers (01/02/03/04) instead of
       icons; uniform, calm, doesn't pull focus from the CTA. */
    .my-pins__anon-faq {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding-left: 2rem;
      border-left: 1px solid var(--nbg-hairline, #e1e6ed);
    }
    @media (max-width: 880px) {
      .my-pins__anon-faq {
        padding-left: 0;
        padding-top: 1.5rem;
        border-left: 0;
        border-top: 1px solid var(--nbg-hairline, #e1e6ed);
      }
    }
    .my-pins__anon-faq-heading {
      margin: 0 0 0.25rem;
      font-family: var(--nbg-ff-body);
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--nbg-ink, #1a2030);
      letter-spacing: -0.005em;
    }
    .my-pins__faq-list {
      display: grid;
      gap: 0.85rem;
    }
    .my-pins__faq-item {
      display: grid;
      grid-template-columns: 2.4rem 1fr;
      gap: 0.5rem;
      align-items: start;
    }
    .my-pins__faq-num {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--nbg-accent, #0a8a7d);
      padding-top: 0.15rem;
    }
    .my-pins__faq-body { display: grid; gap: 0.15rem; }
    .my-pins__faq-body h4 {
      margin: 0;
      font-family: var(--nbg-ff-body);
      font-size: 0.8125rem;
      font-weight: 600;
      color: var(--nbg-ink, #1a2030);
      letter-spacing: -0.003em;
    }
    .my-pins__faq-body p {
      margin: 0;
      font-size: 0.8125rem;
      line-height: 1.5;
      color: var(--nbg-muted, #6b7280);
    }
    .my-pins__faq-body code {
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.75rem;
      padding: 1px 4px;
      border-radius: 3px;
      background: var(--nbg-surface-2, #f6f8fa);
      border: 1px solid var(--nbg-hairline, #e1e6ed);
    }
    .my-pins__faq-body a {
      color: var(--nbg-accent, #0a8a7d);
      text-decoration: none;
      border-bottom: 1px solid color-mix(in srgb, var(--nbg-accent, #0a8a7d) 40%, transparent);
    }
    .my-pins__faq-body a:hover {
      border-bottom-color: var(--nbg-accent, #0a8a7d);
    }

    .my-pins__empty-chips {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-top: 0.5rem;
    }

    /* Group heading — single quiet mono eyebrow label. The previous design
       paired an Eyebrow primitive ABOVE a serif h3 with the same text, which
       read as duplication. One label per group: small, mono, all-caps. */
    .my-pins__group-heading {
      margin: 0;
      font-family: var(--nbg-ff-mono, ui-monospace, monospace);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--nbg-muted, var(--nbg-color-fg-muted, #5b6478));
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--nbg-hairline, var(--nbg-color-border-subtle, #e1e6ed));
    }

    /* PAT explainer — quiet "what / why / safe / don't have" block on the
       anonymous-state card. Hairline border + muted background so it sits
       under the headline like a footnote, not a competing CTA. */
    /* Sign-in button — sized to fit the new 2-column layout. align-self
       keeps it left-aligned in the flex column. */
    .my-pins__signin-btn {
      align-self: flex-start;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--nbg-sp-2);
      padding: 0.75rem 1.25rem;
      border: 1px solid var(--nbg-color-accent-strong);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-accent-strong);
      color: var(--nbg-color-fg-on-accent);
      font-family: var(--nbg-type-body);
      font-size: 0.9375rem;
      font-weight: var(--nbg-fw-semibold);
      letter-spacing: var(--nbg-ls-normal);
      line-height: 1;
      cursor: pointer;
      user-select: none;
      margin-top: 0.25rem;
      transition: background-color var(--nbg-dur-fast) var(--nbg-ease-out),
                  border-color     var(--nbg-dur-fast) var(--nbg-ease-out),
                  transform        var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .my-pins__signin-btn:hover {
      background: var(--nbg-color-accent-hover);
      border-color: var(--nbg-color-accent-hover);
      transform: translateY(-1px);
    }
    .my-pins__signin-btn:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* ── Filter chips ──────────────────────────────────────────────── */
    .my-pins__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
    }
    .my-pins__filters[hidden] { display: none; }
    .my-pins__filter-chip {
      /* !important across every dimension property — Starlight ships its
         own button/chip rules unlayered, which win the cascade in the
         deployed build (not in dev) per the documented Starlight gotcha.
         Without these flags the *pressed* state ends up taller + with a
         larger label and count bubble than the unpressed state, even
         though both share this class. See docs/reference/starlight-
         cascade-gotcha.md. Same pattern as the homepage router-grid fix
         in DECISIONS 2026-05-25. margin: 0 also kills the .sl-markdown-
         content sibling-margin rule that would push every chip after
         the first by 16px. */
      display: inline-flex !important;
      align-items: center !important;
      gap: 0.5rem !important;
      height: 2.25rem !important;
      min-height: 2.25rem !important;
      margin: 0 !important;
      padding: 0 0.95rem !important;
      border-radius: 999px !important;
      border: 1px solid color-mix(in srgb, var(--nbg-ink, #1a2030) 14%, transparent);
      background: var(--nbg-bg, #fff);
      color: var(--nbg-ink-2, #4a5563);
      font-family: var(--nbg-ff-body) !important;
      font-size: 0.8125rem !important;
      font-weight: 500 !important;
      line-height: 1 !important;
      cursor: pointer;
      box-sizing: border-box !important;
      transition: background-color 140ms ease, border-color 140ms ease, color 140ms ease;
    }
    /* Inner spans must INHERIT the chip's font-size / line-height. Without
       these guards a Starlight body rule on `button > span` (or markdown
       content typography) re-asserts its own font-size and the pressed
       state visually expands. Belt-and-braces with the chip-level
       !importants above. */
    .my-pins__filter-chip > span {
      font-size: inherit !important;
      font-weight: inherit !important;
      line-height: inherit !important;
      letter-spacing: inherit !important;
      font-family: inherit !important;
    }
    .my-pins__filter-chip:hover {
      background: var(--nbg-surface-2, #eef2f7);
      border-color: color-mix(in srgb, var(--nbg-ink, #1a2030) 30%, transparent);
      color: var(--nbg-ink, #1a2030);
    }
    .my-pins__filter-chip[aria-pressed='true'] {
      background: var(--nbg-ink, #1a2030);
      border-color: var(--nbg-ink, #1a2030);
      color: var(--nbg-bg, #fff);
    }
    /* Count badge — sits inside the chip on its own small bubble. Sized so
