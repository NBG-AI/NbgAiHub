---
// site/src/pages/my-pins.astro
//
// /my-pins/ — the per-user pinned-items dashboard (F-P11, project-design.md §P.4.4).
//
// Server-side render: two static panels (anonymous + signed-in skeleton) plus
// a loading state. The client `<script>` reads auth state, hydrates the
// signed-in panel by joining the user's gist favourites with the build-time
// pin indices (one /_data/<type>-index.json per type, emitted by
// scripts/build-pin-index.ts), and wires Unpin buttons through gist.ts.
//
// No raw fetch calls in this file — all gist + pin-index access is via the
// shared lib modules.
//
// Phase 6 / P4.H — Personalization Surfaces (Coder-H). Visual chrome migrated
// onto MarketingShell + primitives. The 14 data-* hooks, 2 ARIA-labelled
// section IDs, role="alert", and the entire <script> block are preserved
// bit-for-bit (AC23 + AC34). See project-design.md §S.13.10.10.

import MarketingShell from '../components/MarketingShell.astro';
import Section from '../components/primitives/Section.astro';
import Stack from '../components/primitives/Stack.astro';
import Cluster from '../components/primitives/Cluster.astro';
import Card from '../components/primitives/Card.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import Display from '../components/primitives/Display.astro';
import Lede from '../components/primitives/Lede.astro';

// F-P11 display order — repeated server-side so SSR markup matches the
// client-side iteration order.
const PIN_TYPE_HEADINGS: ReadonlyArray<{
  type: 'skill' | 'tip' | 'news' | 'journey-step' | 'glossary';
  label: string;
}> = [
  { type: 'skill', label: 'Skills' },
  { type: 'tip', label: 'Tips & Tricks' },
  { type: 'news', label: 'News' },
  { type: 'journey-step', label: 'Journey steps' },
  { type: 'glossary', label: 'Glossary terms' },
];
---

<MarketingShell
  title="My Pins"
  description="Your personal pinned-items dashboard. Pins live in your own GitHub gist (unlisted) — they are not shared with the team."
  surfaceId="my-pins"
  width="default"
>
  <Stack slot="hero" gap="4">
    <Eyebrow tone="accent">Personal</Eyebrow>
    <Display level={1} size="lg">My Pins</Display>
    <Lede size="lg">
      Your personal pinned-items dashboard. Pins live in your own GitHub gist
      (unlisted) — they are not shared with the team.
    </Lede>
  </Stack>

  <Stack gap="12">
    {/* Loading state — visible by default, hidden by the script once auth
        state is determined. Tokenised skeleton-style placeholder. */}
    <Section spacing="snug" tone="subtle" as="div">
      <div class="my-pins__loading" data-my-pins-loading>
        <span class="my-pins__skeleton" aria-hidden="true"></span>
        <span class="my-pins__skeleton" aria-hidden="true"></span>
        <span class="my-pins__skeleton" aria-hidden="true"></span>
        <p class="sr-only">Loading your pins…</p>
      </div>
    </Section>

    {/* Anonymous panel — shown when readToken() returns null. */}
    <section
      class="my-pins__anonymous"
      data-my-pins-anonymous
      hidden
      aria-labelledby="my-pins-anon-heading"
    >
      <Card variant="feature">
        <Stack gap="4">
          <Eyebrow tone="accent">Sign in</Eyebrow>
          <h2 id="my-pins-anon-heading" class="my-pins__anon-heading">
            Sign in to see your pins
          </h2>
          <Lede>
            Pinning is per-user and stored in a private gist on your GitHub
            account. Sign in to view, add, or remove pins.
          </Lede>
          <Cluster gap="3">
            <button
              type="button"
              class="my-pins__signin-btn"
              data-my-pins-signin
            >
              Sign in
            </button>
          </Cluster>
        </Stack>
      </Card>
    </section>

    {/* Signed-in panel — populated by the script. The five type sections
        render in F-P11 order regardless of pin count; empty sections show a
        small "(none)" placeholder. */}
    <section
      class="my-pins__signed-in"
      data-my-pins-signed-in
      hidden
      aria-labelledby="my-pins-signed-in-heading"
    >
      <h2 id="my-pins-signed-in-heading" class="sr-only">Your pinned items</h2>

      <Stack gap="8">
        <p data-my-pins-empty hidden class="my-pins__empty">
          You haven't pinned anything yet. Click the pin button on any news
          item, tip, skill, glossary term, or journey step to pin it here.
        </p>

        <p
          data-my-pins-error
          hidden
          class="my-pins__error"
          role="alert"
        ></p>

        {PIN_TYPE_HEADINGS.map(({ type, label }) => (
          <section class="my-pins__group" data-pin-group={type}>
            <Stack gap="3">
              <Eyebrow tone="accent">{label}</Eyebrow>
              <h3 class="my-pins__group-heading">{label}</h3>
              <p data-pin-group-empty={type} class="my-pins__group-empty" hidden>
                (none)
              </p>
              <ul class="my-pins__list" data-pin-list={type}></ul>
            </Stack>
          </section>
        ))}
      </Stack>
    </section>

    {/* Privacy callout (F-P21) — editorial aside on subtle tone. */}
    <Section spacing="default" tone="subtle" as="aside" aria-label="Privacy">
      <Stack gap="3">
        <Eyebrow>Privacy</Eyebrow>
        <Display level={3} size="sm">How pins are stored</Display>
        <p class="my-pins__privacy-body">
          Your pins live in your own GitHub gist (unlisted). They're not
          shared with the team. Clearing your token signs out and removes the
          <code>gist_id</code> from this browser, but does not delete the
          gist itself — go to <a
            href="https://github.com/settings/tokens"
            target="_blank"
            rel="noopener noreferrer"
          >github.com/settings/tokens</a> to revoke access.
        </p>
      </Stack>
    </Section>
  </Stack>
</MarketingShell>

<style>
  @layer nbg.components {
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }

    /* Loading state — opacity-pulsing token-driven skeleton placeholders. */
    .my-pins__loading {
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-3);
    }
    .my-pins__skeleton {
      display: block;
      height: var(--nbg-sp-5);
      border-radius: var(--nbg-r-sm);
      background: var(--nbg-color-bg-surface);
      animation: nbg-skeleton-pulse var(--nbg-dur-slow, 1.5s) ease-in-out infinite;
    }
    .my-pins__skeleton:nth-child(1) { width: 65%; }
    .my-pins__skeleton:nth-child(2) { width: 80%; }
    .my-pins__skeleton:nth-child(3) { width: 45%; }

    @keyframes nbg-skeleton-pulse {
      0%, 100% { opacity: 0.55; }
      50%      { opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .my-pins__skeleton { animation: none; opacity: 0.75; }
    }

    /* Anonymous-state heading — mirrors Display level=2 size=sm look, but is
       a real <h2 id> so the surrounding section can use aria-labelledby
       without a Display-primitive prop forwarding change. */
    .my-pins__anon-heading {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-display-sm);
      font-weight: var(--nbg-fw-bold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-display);
      color: var(--nbg-color-fg-primary);
      font-variation-settings: 'opsz' var(--nbg-opsz-display);
      text-wrap: balance;
    }

    /* Group heading — sits below the accent Eyebrow as the semantic label.
       Display primitive is reserved for hero + privacy callout; group rows
       use a quieter heading so the eye reads the list, not the labels. */
    .my-pins__group-heading {
      margin: 0;
      font-family: var(--nbg-type-display);
      font-size: var(--nbg-fs-xl);
      font-weight: var(--nbg-fw-semibold);
      letter-spacing: var(--nbg-ls-tight);
      line-height: var(--nbg-lh-tight);
      color: var(--nbg-color-fg-primary);
    }

    /* Anonymous-state sign-in button — token-driven primary CTA. Plain
       <button> rather than the Button primitive because the script reads
       its `data-my-pins-signin` attribute via querySelector. */
    .my-pins__signin-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--nbg-sp-2);
      padding: var(--nbg-sp-3) var(--nbg-sp-6);
      border: 1px solid var(--nbg-color-accent-strong);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-accent-strong);
      color: var(--nbg-color-fg-on-accent);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-lg);
      font-weight: var(--nbg-fw-semibold);
      letter-spacing: var(--nbg-ls-normal);
      line-height: 1;
      cursor: pointer;
      user-select: none;
      transition: background-color var(--nbg-dur-fast) var(--nbg-ease-out),
                  border-color     var(--nbg-dur-fast) var(--nbg-ease-out),
                  transform        var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .my-pins__signin-btn:hover {
      background: var(--nbg-color-accent-hover);
      border-color: var(--nbg-color-accent-hover);
      transform: translateY(-1px);
    }
    .my-pins__signin-btn:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }

    /* List rendering — preserved selectors. The JS dynamically appends <li>
       children into ul[data-pin-list], so the styling has to live on these
       class names (.my-pins__list, .my-pins__stale, .my-pins__unpin,
       .my-pins__audience, .my-pins__audience--*). */
    .my-pins__list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--nbg-sp-2);
    }

    .my-pins__list li {
      display: flex;
      align-items: center;
      gap: var(--nbg-sp-3);
      padding: var(--nbg-sp-2) var(--nbg-sp-3);
      border: 1px solid var(--nbg-color-border-subtle);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-bg-surface);
      transition: background-color var(--nbg-dur-base) var(--nbg-ease-out),
                  border-color     var(--nbg-dur-base) var(--nbg-ease-out);
    }
    .my-pins__list li:hover {
      background: var(--nbg-color-bg-surface-hover);
      border-color: var(--nbg-color-border-default);
    }

    .my-pins__list li.my-pins__stale {
      opacity: 0.55;
      font-style: italic;
    }

    .my-pins__list a {
      color: var(--nbg-color-link);
      text-decoration: none;
      font-weight: var(--nbg-fw-semibold);
    }
    .my-pins__list a:hover {
      color: var(--nbg-color-link-hover);
      text-decoration: underline;
    }

    /* Audience labels created dynamically in JS — token-driven via the
       Badge tone palette. */
    .my-pins__audience {
      display: inline-flex;
      align-items: center;
      padding: var(--nbg-sp-0-5) var(--nbg-sp-2);
      border-radius: var(--nbg-r-pill);
      font-family: var(--nbg-type-body);
      font-size: var(--nbg-fs-xs);
      font-weight: var(--nbg-fw-medium);
      letter-spacing: var(--nbg-ls-loose);
      line-height: 1.3;
      background: var(--nbg-color-bg-surface);
      color: var(--nbg-color-fg-secondary);
    }
    .my-pins__audience--beginner {
      background: var(--nbg-color-audience-beginner-bg);
      color: var(--nbg-color-audience-beginner-fg);
    }
    .my-pins__audience--advanced {
      background: var(--nbg-color-audience-advanced-bg);
      color: var(--nbg-color-audience-advanced-fg);
    }
    .my-pins__audience--both {
      background: var(--nbg-color-audience-both-bg);
      color: var(--nbg-color-audience-both-fg);
    }

    .my-pins__unpin {
      margin-left: auto;
      padding: var(--nbg-sp-1) var(--nbg-sp-3);
      border-radius: var(--nbg-r-md);
      border: 1px solid var(--nbg-color-border-default);
      background: transparent;
      color: var(--nbg-color-fg-secondary);
      font: inherit;
      font-size: var(--nbg-fs-sm);
      font-weight: var(--nbg-fw-medium);
      cursor: pointer;
      transition: background-color var(--nbg-dur-fast) var(--nbg-ease-out),
                  border-color     var(--nbg-dur-fast) var(--nbg-ease-out),
                  color            var(--nbg-dur-fast) var(--nbg-ease-out);
    }
    .my-pins__unpin:hover {
      background: var(--nbg-color-bg-surface-hover);
      border-color: var(--nbg-color-border-strong);
      color: var(--nbg-color-fg-primary);
    }
    .my-pins__unpin:focus-visible {
      outline: none;
      box-shadow: var(--nbg-sh-focus-ring);
    }
    .my-pins__unpin[disabled] {
      opacity: 0.6;
      cursor: progress;
    }

    .my-pins__empty {
      padding: var(--nbg-sp-4) var(--nbg-sp-5);
      border: 1px dashed var(--nbg-color-border-default);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-bg-page);
      color: var(--nbg-color-fg-secondary);
      margin: 0;
    }

    .my-pins__error {
      padding: var(--nbg-sp-2) var(--nbg-sp-4);
      border-radius: var(--nbg-r-md);
      background: var(--nbg-color-status-danger-bg);
      color: var(--nbg-color-status-danger-fg);
      border: 1px solid var(--nbg-color-status-danger-fg);
      margin: 0;
    }

    .my-pins__group-empty {
      opacity: 0.7;
      font-size: var(--nbg-fs-sm);
      color: var(--nbg-color-fg-muted);
      margin: 0;
    }

    .my-pins__privacy-body {
      margin: 0;
      max-width: 64ch;
      color: var(--nbg-color-fg-secondary);
      line-height: var(--nbg-lh-relaxed);
    }
    .my-pins__privacy-body code {
      font-family: var(--nbg-type-mono);
      font-size: 0.9em;
      padding: 0 var(--nbg-sp-1);
      border-radius: var(--nbg-r-sm);
      background: var(--nbg-color-bg-surface);
      color: var(--nbg-color-accent);
    }
    .my-pins__privacy-body a {
      color: var(--nbg-color-link);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .my-pins__privacy-body a:hover {
      color: var(--nbg-color-link-hover);
    }
  }
</style>

<script>
  import { readToken, subscribe } from '../lib/auth.ts';
  import { findOrCreateFavoritesGist, removeFavorite } from '../lib/gist.ts';
  import {
    fetchAllPinIndices,
    joinFavoritesWithIndex,
    groupFavoritesByType,
    type HydratedPin,
  } from '../lib/pin-store.ts';

  type PinType = 'skill' | 'tip' | 'news' | 'journey-step' | 'glossary';

  /** Map (type, slug) -> on-site URL for the title link. Best-effort. */
  function urlForPin(type: PinType, slug: string): string {
    switch (type) {
      case 'news':
        return `/news/${slug}/`;
      case 'skill':
        return `/skills/`;
      case 'tip':
        return `/tips/`;
      case 'glossary':
        return `/glossary#${slug}`;
      case 'journey-step':
        return `/start-here/${slug}/`;
    }
  }

  function getLoading(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-loading]');
  }
  function getAnonymous(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-anonymous]');
  }
  function getSignedIn(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-signed-in]');
  }
  function getEmpty(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-empty]');
  }
  function getErrorBox(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-error]');
  }

  function show(el: HTMLElement | null): void {
    if (el !== null) el.hidden = false;
  }
  function hide(el: HTMLElement | null): void {
    if (el !== null) el.hidden = true;
  }

  function setError(message: string | null): void {
    const box = getErrorBox();
    if (box === null) return;
    if (message === null) {
      box.textContent = '';
      box.hidden = true;
    } else {
      box.textContent = message;
      box.hidden = false;
    }
  }

  function clearAllLists(): void {
    const lists = document.querySelectorAll<HTMLUListElement>('ul[data-pin-list]');
    lists.forEach((ul) => {
      ul.replaceChildren();
    });
    const placeholders = document.querySelectorAll<HTMLElement>(
      '[data-pin-group-empty]',
    );
    placeholders.forEach((p) => {
      p.hidden = true;
    });
  }

  function readAuthState(): { token: string } | null {
    try {
      return readToken();
    } catch {
      return null;
    }
  }

  function showAnonymousPanel(): void {
    hide(getLoading());
    hide(getSignedIn());
    show(getAnonymous());
  }

  function showLoadingState(): void {
    show(getLoading());
    hide(getAnonymous());
    hide(getSignedIn());
  }

  function showSignedInPanel(): void {
    hide(getLoading());
    hide(getAnonymous());
    show(getSignedIn());
  }

  function audienceLabel(audience: 'beginner' | 'advanced' | 'both'): HTMLSpanElement {
    const span = document.createElement('span');
    span.className = `my-pins__audience my-pins__audience--${audience}`;
    span.textContent = audience;
    return span;
  }

  function buildPinListItem(
    pin: HydratedPin,
    onUnpin: (pin: HydratedPin, li: HTMLLIElement) => void,
  ): HTMLLIElement {
    const li = document.createElement('li');
    li.dataset.pinSlug = pin.slug;
    li.dataset.pinType = pin.type;

    if (pin.display !== null) {
      const a = document.createElement('a');
      a.href = urlForPin(pin.type as PinType, pin.slug);
      a.textContent = pin.display.title;
      li.appendChild(a);
      li.appendChild(audienceLabel(pin.display.audience));
    } else {
      li.classList.add('my-pins__stale');
      const span = document.createElement('span');
      span.textContent = `Pinned item no longer available (${pin.type}/${pin.slug})`;
      li.appendChild(span);
    }

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'my-pins__unpin';
    btn.textContent = 'Unpin';
    btn.setAttribute('aria-label', `Unpin ${pin.display?.title ?? pin.slug}`);
    btn.addEventListener('click', () => onUnpin(pin, li));
    li.appendChild(btn);

    return li;
  }

  async function renderSignedIn(token: string): Promise<void> {
    showLoadingState();
    setError(null);
    clearAllLists();
    hide(getEmpty());

    let gistId: string;
    let favourites: HydratedPin[] = [];
    try {
      const gistResult = await findOrCreateFavoritesGist(token);
      gistId = gistResult.gistId;
      const indices = await fetchAllPinIndices();
      favourites = joinFavoritesWithIndex(gistResult.document.favourites, indices);
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      // Show the signed-in panel with whatever loaded (likely nothing) plus
      // an inline error. Per spec, we keep the panel visible on fetch failure.
      showSignedInPanel();
      setError(`Could not load your pins: ${msg}`);
      show(getEmpty());
      return;
    }

    const grouped = groupFavoritesByType(favourites);

    if (favourites.length === 0) {
      showSignedInPanel();
      show(getEmpty());
      return;
    }

    const onUnpin = async (pin: HydratedPin, li: HTMLLIElement): Promise<void> => {
      const btn = li.querySelector<HTMLButtonElement>('.my-pins__unpin');
      // Snapshot for revert on failure.
      const parent = li.parentElement;
      const nextSibling = li.nextSibling;
      if (btn !== null) btn.disabled = true;
      // Optimistic removal.
      li.remove();
      // If the type group now has zero items, show the (none) placeholder.
      maybeMarkGroupEmpty(pin.type as PinType);
      try {
        await removeFavorite(token, gistId, { type: pin.type, slug: pin.slug });
        // Check the whole-page empty state.
        const anyLeft = document.querySelector<HTMLLIElement>(
          'ul[data-pin-list] > li',
        );
        if (anyLeft === null) {
          show(getEmpty());
        }
      } catch (err) {
        // Revert.
        if (parent !== null) {
          parent.insertBefore(li, nextSibling);
        }
        // Group is no longer empty — hide placeholder.
        maybeMarkGroupEmpty(pin.type as PinType);
        if (btn !== null) btn.disabled = false;
        const msg = err instanceof Error ? err.message : String(err);
        setError(`Could not unpin: ${msg}`);
      }
    };

    for (const type of [
      'skill',
      'tip',
      'news',
      'journey-step',
      'glossary',
    ] as const) {
      const ul = document.querySelector<HTMLUListElement>(
        `ul[data-pin-list="${type}"]`,
      );
      if (ul === null) continue;
      const pins = grouped[type];
      if (pins.length === 0) {
        const placeholder = document.querySelector<HTMLElement>(
          `[data-pin-group-empty="${type}"]`,
        );
        if (placeholder !== null) placeholder.hidden = false;
        continue;
      }
      for (const pin of pins) {
        ul.appendChild(buildPinListItem(pin, onUnpin));
      }
    }

    showSignedInPanel();
  }

  function maybeMarkGroupEmpty(type: PinType): void {
    const ul = document.querySelector<HTMLUListElement>(
      `ul[data-pin-list="${type}"]`,
    );
    const placeholder = document.querySelector<HTMLElement>(
      `[data-pin-group-empty="${type}"]`,
    );
    if (ul === null || placeholder === null) return;
    placeholder.hidden = ul.children.length !== 0;
  }

  function wireSignInButton(): void {
    const btn = document.querySelector<HTMLButtonElement>('[data-my-pins-signin]');
    if (btn === null) return;
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('nbgaihub:open-signin-modal'));
    });
  }

  async function render(): Promise<void> {
    const state = readAuthState();
    if (state === null) {
      showAnonymousPanel();
      return;
    }
    await renderSignedIn(state.token);
  }

  function init(): void {
    wireSignInButton();
    void render();

    subscribe((authState) => {
      if (authState === 'signed-out') {
        showAnonymousPanel();
      } else {
        void render();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
