      font-weight: 500 !important;
      line-height: 1 !important;
      box-sizing: border-box !important;
    }
    .my-pins__filter-chip[aria-pressed='true'] .my-pins__filter-chip__count {
      background: color-mix(in srgb, var(--nbg-bg, #fff) 20%, transparent);
    }

    /* ── Pin grid ──────────────────────────────────────────────────── */
    .my-pins__grid {
      list-style: none;
      margin: 0;
