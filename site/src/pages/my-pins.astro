</style>

<script>
  import {
    readToken,
    signOut,
    subscribe,
    markTokenRejected,
    wasTokenRejected,
    clearTokenRejectedFlag,
  } from '../lib/auth.ts';
  import { TokenInvalidError } from '../lib/api-fetch.ts';
  import { findOrCreateFavoritesGist, removeFavorite } from '../lib/gist.ts';
  import {
    fetchAllPinIndices,
    joinFavoritesWithIndex,
    groupFavoritesByType,
    PIN_TYPE_ORDER,
    type HydratedPin,
  } from '../lib/pin-store.ts';
  import type { FavoriteEntry } from '../lib/gist.ts';

  type PinType = FavoriteEntry['type'];

  /** Map (type, slug) -> on-site URL for the title link. Resolved relative
   *  to the deployed base path (/NbgAiHub/ on Pages, / locally). */
  function urlForPin(type: PinType, slug: string): string {
    const base = (import.meta.env.BASE_URL ?? '/').replace(/\/+$/, '');
    switch (type) {
      case 'skill':
        // No per-skill detail page; route to the listing.
        return `${base}/skills/`;
      case 'tip':
        // Tips DO have per-slug detail pages at /tips/<slug>/.
        return `${base}/tips/${slug}/`;
      case 'use-case':
        // Use cases have per-slug walkthroughs at /use-cases/<slug>/.
        return `${base}/use-cases/${slug}/`;
      case 'glossary':
        return `${base}/glossary/#${slug}`;
      case 'journey-step':
        return `${base}/start-here/${slug}/`;
    }
  }

  /** Pretty-print "today / yesterday / N days ago / Mon DD" from a YYYY-MM-DD. */
  function prettyPinnedAt(yyyymmdd: string): string {
    const m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(yyyymmdd);
    if (m === null) return yyyymmdd;
    const then = new Date(Number(m[1]), Number(m[2]) - 1, Number(m[3]));
    const now = new Date();
    const stripTime = (d: Date) => new Date(d.getFullYear(), d.getMonth(), d.getDate()).getTime();
    const days = Math.round((stripTime(now) - stripTime(then)) / 86_400_000);
    if (days <= 0) return 'today';
    if (days === 1) return 'yesterday';
    if (days < 7) return `${days} days ago`;
    if (days < 14) return 'last week';
    if (days < 60) return `${Math.floor(days / 7)} weeks ago`;
    return then.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
  }

  function getLoading(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-loading]');
  }
  function getAnonymous(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-anonymous]');
  }
  function getSignedIn(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-signed-in]');
  }
  function getEmpty(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-empty]');
  }
  function getErrorBox(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-error]');
  }

  function show(el: HTMLElement | null): void {
    if (el !== null) el.hidden = false;
  }
  function hide(el: HTMLElement | null): void {
    if (el !== null) el.hidden = true;
  }

  function setError(message: string | null): void {
    const box = getErrorBox();
    if (box === null) return;
    if (message === null) {
      box.textContent = '';
      box.hidden = true;
    } else {
      box.textContent = message;
      box.hidden = false;
    }
  }

  function getGrid(): HTMLUListElement | null {
    return document.querySelector<HTMLUListElement>('ul[data-pin-list]');
  }
  function getFiltersBox(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-filters]');
  }

  function getLibraryHeader(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-library-header]');
  }
  function getStatsLine(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-stats]');
  }

  function clearGridAndFilters(): void {
    const grid = getGrid();
    if (grid !== null) grid.replaceChildren();
    const filters = getFiltersBox();
    if (filters !== null) {
      filters.replaceChildren();
      filters.hidden = true;
    }
    const header = getLibraryHeader();
    if (header !== null) header.hidden = true;
    const stats = getStatsLine();
    if (stats !== null) stats.textContent = '';
  }

  /** Build the "2 pinned items · 1 tip · 1 glossary term" summary string. */
  function buildStatsText(grouped: Record<PinType, HydratedPin[]>, total: number): string {
    const TYPE_SINGULAR: Record<PinType, string> = {
      skill: 'skill',
      tip: 'tip',
      'use-case': 'use case',
      'journey-step': 'journey step',
      glossary: 'glossary term',
    };
    const TYPE_PLURAL: Record<PinType, string> = {
      skill: 'skills',
      tip: 'tips',
      'use-case': 'use cases',
      'journey-step': 'journey steps',
      glossary: 'glossary terms',
    };
    const breakdown: string[] = [];
    PIN_TYPE_ORDER.forEach((t) => {
      const n = grouped[t].length;
      if (n > 0) breakdown.push(`${n} ${n === 1 ? TYPE_SINGULAR[t] : TYPE_PLURAL[t]}`);
    });
    const totalText = `${total} pinned item${total === 1 ? '' : 's'}`;
    return breakdown.length > 1 ? `${totalText} · ${breakdown.join(' · ')}` : totalText;
  }

  function readTypeLabels(): Record<string, string> {
    const node = document.getElementById('nbg-my-pins-type-labels');
    if (node === null) return {};
    try {
      return JSON.parse(node.textContent ?? '{}') as Record<string, string>;
    } catch {
      return {};
    }
  }
  const TYPE_LABELS = readTypeLabels();
  function labelForType(type: string): string {
    return TYPE_LABELS[type] ?? type;
  }

  function readAuthState(): { token: string } | null {
    try {
      return readToken();
    } catch {
      return null;
    }
  }

  function getRejectionBanner(): HTMLElement | null {
    return document.querySelector<HTMLElement>('[data-my-pins-rejection-banner]');
  }

  function syncRejectionBanner(): void {
    const banner = getRejectionBanner();
    if (banner === null) return;
    banner.hidden = !wasTokenRejected();
  }

  function showAnonymousPanel(): void {
    hide(getLoading());
    hide(getSignedIn());
    show(getAnonymous());
    syncRejectionBanner();
  }

  function showLoadingState(): void {
    show(getLoading());
    hide(getAnonymous());
    hide(getSignedIn());
  }

  function showSignedInPanel(): void {
    hide(getLoading());
    hide(getAnonymous());
    show(getSignedIn());
  }

  /** Cap the number of topic pills shown on a single card. */
  const MAX_TOPIC_PILLS = 3;

  function buildPinCard(
    pin: HydratedPin,
    onUnpin: (pin: HydratedPin, card: HTMLLIElement) => void,
  ): HTMLLIElement {
    const li = document.createElement('li');
    li.className = 'my-pins__card';
    if (pin.display !== null) li.classList.add('my-pins__card--linked');
    li.dataset.pinSlug = pin.slug;
    li.dataset.pinType = pin.type;

    // Eyebrow row — type label · relative pinned time. Mono, muted, sits
    // at the top of the card like a listing-row eyebrow elsewhere on the
    // site. Pairs visually with /tips and /skills rows.
    const eyebrow = document.createElement('p');
    eyebrow.className = 'my-pins__card-eyebrow';
    const typeSpan = document.createElement('span');
    typeSpan.className = 'my-pins__card-eyebrow-type';
    typeSpan.textContent = labelForType(pin.type);
    eyebrow.appendChild(typeSpan);
    const sep = document.createElement('span');
    sep.className = 'my-pins__card-eyebrow-sep';
    sep.textContent = '·';
    eyebrow.appendChild(sep);
    const when = document.createElement('span');
    when.className = 'my-pins__card-eyebrow-when';
    when.textContent = `pinned ${prettyPinnedAt(pin.pinned_at)}`;
    eyebrow.appendChild(when);
    li.appendChild(eyebrow);

    // Title (the link). When the item is no longer in the index we render
    // a non-link stale message instead — same as the previous behaviour.
    const title = document.createElement('h3');
    title.className = 'my-pins__card-title';
    if (pin.display !== null) {
      const a = document.createElement('a');
      a.className = 'my-pins__card-title-link';
      a.href = urlForPin(pin.type as PinType, pin.slug);
      a.textContent = pin.display.title;
      title.appendChild(a);
    } else {
      li.classList.add('my-pins__stale');
      title.textContent = `No longer available (${pin.type}/${pin.slug})`;
    }
    li.appendChild(title);

    // Topic pills — first MAX_TOPIC_PILLS topics from the pin-index entry,
    // rendered as quiet rounded pills. `pointer-events: none` so the
    // stretched title link still owns click-anywhere navigation.
    if (pin.display !== null && pin.display.topics.length > 0) {
      const pills = document.createElement('div');
      pills.className = 'my-pins__card-pills';
      const shown = pin.display.topics.slice(0, MAX_TOPIC_PILLS);
      for (const topic of shown) {
        const pill = document.createElement('span');
        pill.className = 'my-pins__card-pill';
        pill.textContent = topic;
        pills.appendChild(pill);
      }
      const extra = pin.display.topics.length - shown.length;
      if (extra > 0) {
        const more = document.createElement('span');
        more.className = 'my-pins__card-pill my-pins__card-pill--more';
        more.textContent = `+${extra}`;
        pills.appendChild(more);
      }
      li.appendChild(pills);
    }

    // Footer meta line — audience tag pushed to card bottom via margin-top:auto.
    if (pin.display !== null) {
      const meta = document.createElement('div');
      meta.className = 'my-pins__card-meta';
      const audience = document.createElement('span');
      audience.className = `my-pins__card-audience my-pins__card-audience--${pin.display.audience}`;
      audience.textContent = pin.display.audience;
      meta.appendChild(audience);
      li.appendChild(meta);
    }

    // × unpin — fades in on hover or focus, top-right corner.
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'my-pins__card-unpin';
    btn.textContent = '×';
    btn.setAttribute('aria-label', `Unpin ${pin.display?.title ?? pin.slug}`);
    btn.addEventListener('click', (event) => {
      // Don't let the stretched title-link overlay swallow the click.
      event.preventDefault();
      event.stopPropagation();
      onUnpin(pin, li);
    });
    li.appendChild(btn);

    return li;
  }

  /** Build the filter chip row. Only emits chips for types that have ≥1 pin. */
  function buildFilters(grouped: Record<PinType, HydratedPin[]>, totalCount: number): void {
    const box = getFiltersBox();
    if (box === null) return;
    box.replaceChildren();

    const onChipClick = (filterType: PinType | 'all', clicked: HTMLButtonElement): void => {
      const allChips = box.querySelectorAll<HTMLButtonElement>('.my-pins__filter-chip');
      allChips.forEach((c) => c.setAttribute('aria-pressed', 'false'));
      clicked.setAttribute('aria-pressed', 'true');
      const cards = document.querySelectorAll<HTMLLIElement>('.my-pins__card');
      cards.forEach((card) => {
        const show = filterType === 'all' || card.dataset.pinType === filterType;
        card.dataset.pinHidden = show ? 'false' : 'true';
      });
    };

    const makeChip = (filterType: PinType | 'all', label: string, count: number, pressed: boolean): HTMLButtonElement => {
      const chip = document.createElement('button');
      chip.type = 'button';
      chip.className = 'my-pins__filter-chip';
      chip.setAttribute('role', 'tab');
      chip.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      chip.dataset.filter = filterType;
      const labelSpan = document.createElement('span');
      labelSpan.textContent = label;
      const countSpan = document.createElement('span');
      countSpan.className = 'my-pins__filter-chip__count';
      countSpan.textContent = String(count);
      chip.appendChild(labelSpan);
      chip.appendChild(countSpan);
      chip.addEventListener('click', () => onChipClick(filterType, chip));
      return chip;
    };

    box.appendChild(makeChip('all', 'All', totalCount, true));
    PIN_TYPE_ORDER.forEach((t) => {
      const count = grouped[t].length;
      if (count > 0) box.appendChild(makeChip(t, labelForType(t), count, false));
    });
    box.hidden = false;
  }

  async function renderSignedIn(token: string): Promise<void> {
    try {
      await renderSignedInInner(token);
    } catch (err) {
      // Last-ditch catch — anything thrown between the gist fetch and the
      // final showSignedInPanel() (grouping, card construction, DOM
      // updates, …) ends up here instead of becoming an unhandled
      // rejection that freezes the loading skeleton with no explanation.
      // eslint-disable-next-line no-console
      console.error('[nbgaihub/my-pins] unexpected render failure:', err);
      const msg = err instanceof Error ? err.message : String(err);
      showSignedInPanel();
      setError(`Could not load your pins: ${msg}`);
      show(getEmpty());
    }
  }

  async function renderSignedInInner(token: string): Promise<void> {
    showLoadingState();
    setError(null);
    clearGridAndFilters();
    hide(getEmpty());

    let gistId: string;
    let favourites: HydratedPin[] = [];
    try {
      const gistResult = await findOrCreateFavoritesGist(token);
      gistId = gistResult.gistId;
      // BASE_URL is '/' locally and '/NbgAiHub/' on GitHub Pages — without
      // this prefix the deployed site fetches /_data/tip-index.json against
      // the org-root and 404s. Trailing slash is fine — indexUrlFor trims.
      const indices = await fetchAllPinIndices(import.meta.env.BASE_URL);
      favourites = joinFavoritesWithIndex(gistResult.document.favourites, indices);
    } catch (err) {
      // Token rejected by GitHub (revoked / expired / wrong scope). The
      // stored token is dead — clear it and drop back to the sign-in
      // panel so the user gets a clear "please sign in again" path
      // instead of a wall of JSON. signOut() fires the auth subscriber
      // which re-renders this page in signed-out mode.
      if (err instanceof TokenInvalidError) {
        markTokenRejected();
        signOut();
        return;
      }
      const msg = err instanceof Error ? err.message : String(err);
      showSignedInPanel();
      setError(`Could not load your pins: ${msg}`);
      show(getEmpty());
      return;
    }

    const grouped = groupFavoritesByType(favourites);

    if (favourites.length === 0) {
      showSignedInPanel();
      show(getEmpty());
      return;
    }

    const grid = getGrid();
    if (grid === null) {
      showSignedInPanel();
      return;
    }

    const onUnpin = async (pin: HydratedPin, card: HTMLLIElement): Promise<void> => {
      const btn = card.querySelector<HTMLButtonElement>('.my-pins__card-unpin');
      const parent = card.parentElement;
      const nextSibling = card.nextSibling;
      if (btn !== null) btn.disabled = true;
      // Optimistic removal.
      card.remove();
      try {
        await removeFavorite(token, gistId, { type: pin.type, slug: pin.slug });
        // Refresh filter chips + stats so the counts stay accurate.
        const anyLeft = grid.querySelector<HTMLLIElement>('.my-pins__card');
        if (anyLeft === null) {
          const filters = getFiltersBox();
          if (filters !== null) { filters.replaceChildren(); filters.hidden = true; }
          const header = getLibraryHeader();
          if (header !== null) header.hidden = true;
          show(getEmpty());
        } else {
          // Rebuild chips + stats from remaining cards.
          const remaining: HydratedPin[] = Array.from(
            grid.querySelectorAll<HTMLLIElement>('.my-pins__card'),
          ).map((c) => ({
            slug: c.dataset.pinSlug ?? '',
            type: (c.dataset.pinType ?? 'skill') as PinType,
            display: null,
          })) as unknown as HydratedPin[];
          const regrouped = groupFavoritesByType(remaining);
          buildFilters(regrouped, remaining.length);
          const stats = getStatsLine();
          if (stats !== null) stats.textContent = buildStatsText(regrouped, remaining.length);
        }
      } catch (err) {
        if (parent !== null) parent.insertBefore(card, nextSibling);
        if (btn !== null) btn.disabled = false;
        const msg = err instanceof Error ? err.message : String(err);
        setError(`Could not unpin: ${msg}`);
      }
    };

    PIN_TYPE_ORDER.forEach((type) => {
      for (const pin of grouped[type]) {
        grid.appendChild(buildPinCard(pin, onUnpin));
      }
    });

    buildFilters(grouped, favourites.length);

    // Reveal the library header strip + stats line. Hidden while loading
    // and during the empty state so the page reads as "ah, my pins" not
    // "what is this header for?".
    const header = getLibraryHeader();
    if (header !== null) header.hidden = false;
    const stats = getStatsLine();
    if (stats !== null) stats.textContent = buildStatsText(grouped, favourites.length);

    showSignedInPanel();
  }

  function wireSignInButton(): void {
    const btn = document.querySelector<HTMLButtonElement>('[data-my-pins-signin]');
    if (btn === null) return;
    btn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('nbgaihub:open-signin-modal'));
    });
  }

  function wireRejectionBanner(): void {
    const signinBtn = document.querySelector<HTMLButtonElement>(
      '[data-my-pins-rejection-signin]',
    );
    if (signinBtn !== null) {
      signinBtn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('nbgaihub:open-signin-modal'));
      });
    }
    const dismissBtn = document.querySelector<HTMLButtonElement>(
      '[data-my-pins-rejection-dismiss]',
    );
    if (dismissBtn !== null) {
      dismissBtn.addEventListener('click', () => {
        clearTokenRejectedFlag();
        syncRejectionBanner();
      });
    }
  }

  async function render(): Promise<void> {
    const state = readAuthState();
    if (state === null) {
      showAnonymousPanel();
      return;
    }
    await renderSignedIn(state.token);
  }

  function init(): void {
    wireSignInButton();
    wireRejectionBanner();
    void render();

    subscribe((authState) => {
      if (authState === 'signed-out') {
        showAnonymousPanel();
      } else {
        void render();
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init, { once: true });
  } else {
    init();
  }
</script>
