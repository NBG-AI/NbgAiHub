---
/**
 * /reference — AgentNews-aesthetic reference cheatsheet.
 *
 * Same data buckets as before (slashCommands, filePatterns, triageShortcuts,
 * plannedSkillsIndex, plannedPluginRef). Visual chrome retuned to AgentNews
 * .section + .grid-3 + .card. Disabled "planned" items use the .footer-link--disabled
 * tone.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #6.
 * Backs AC10, AC15.
 */
import MarketingShell from '../components/MarketingShell.astro';

interface PreviewItem {
  title: string;
  body: string;
  href?: string;
  status: 'live' | 'planned';
}

const slashCommands: PreviewItem[] = [
  { title: '/clear', body: 'Wipes the conversation. Use it between unrelated tasks. Cheap context = better answers.', status: 'live' },
  { title: '/init',  body: 'Generates a starter CLAUDE.md for the current repo. Don\'t skip the human pass.', status: 'live' },
  { title: '/cost',  body: 'Shows your token usage for the session. Watch this when you\'re iterating on a big plan.', status: 'live' },
  { title: '/agents',body: 'Manage subagents. Subagents = fresh context window for a sub-task. Huge for long sessions.', status: 'live' },
];

const filePatterns: PreviewItem[] = [
  { title: 'CLAUDE.md (project + global)', body: 'One CLAUDE.md per repo, plus a global ~/.claude/CLAUDE.md. Project rules in the repo; personal preferences global.', status: 'live' },
  { title: 'Issues - Pending Items.md',     body: 'Project-root file where Claude logs unresolved questions.', status: 'live' },
  { title: 'Plan files (docs/design/plan-*.md)', body: 'Write the plan before the code. Reviewing a plan is 10× cheaper than reviewing a diff.', status: 'live' },
];

const triageShortcuts: PreviewItem[] = [
  { title: '"Don\'t write code yet — just outline."',     body: 'Use this every time a feature touches more than one file.', status: 'live' },
  { title: '"List your assumptions before proceeding."', body: 'Catches the AI\'s drift earlier than reading 200 lines of code.', status: 'live' },
  { title: '"What\'s the smallest change that makes this work?"', body: 'Antidote to gold-plating.', status: 'live' },
];

const plannedSkillsIndex: PreviewItem[] = [
  { title: 'team@556LowCodeNoCode-skills', body: 'Where the team\'s curated skills live.', href: 'https://github.com/556LowCodeNoCode/Skills', status: 'planned' },
  { title: 'nbg-ai-hub@nbg-ai-hub-marketplace', body: 'This hub installable as a plugin.', status: 'planned' },
];

const plannedPluginRef: PreviewItem[] = [
  { title: 'Commands', body: 'A flat index of every /hub-* command. Source: plugin/commands/ on GitHub.', href: 'https://github.com/chomovazuzana/NbgAiHub/tree/main/plugin/commands', status: 'planned' },
  { title: 'Manifest', body: 'plugin.json schema — what fields are required, what the marketplace expects.', status: 'planned' },
];

const sections = [
  { id: 'slash-commands', label: 'Slash commands', sub: 'Live · 4 entries', items: slashCommands },
  { id: 'file-patterns',  label: 'File patterns',  sub: 'Live · 3 entries', items: filePatterns },
  { id: 'triage',         label: 'Triage shortcuts', sub: 'Live · 3 entries', items: triageShortcuts },
  { id: 'skills-index',   label: 'Skills indices',   sub: 'Planned · 2 entries', items: plannedSkillsIndex },
  { id: 'plugin-ref',     label: 'Plugin reference', sub: 'Planned · 2 entries', items: plannedPluginRef },
];
---

<MarketingShell
  title="Reference"
  description="A tight cheatsheet. The things you keep needing to look up."
  surfaceId="reference"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">A tight <em>cheatsheet.</em></h1>
        <p class="hero__lede">
          The things you keep needing to look up. Slash commands first;
          the deeper indices land as the hub grows.
          <small>14 entries</small>
        </p>
      </div>
    </div>
  </section>

  {sections.map((section) => (
    <section class="section" id={section.id}>
      <div class="wrap">
        <div class="section__head">
          <h2>{section.label}</h2>
          <span class="count">{section.sub}</span>
        </div>
        <div class="grid-3">
          {section.items.map((item) => (
            <article class={`card card--text ${item.status === 'planned' ? 'card--planned' : ''}`}>
              <div class="card__body">
                <div class="card__meta">
                  <span class={`tag ${item.status === 'live' ? 'tag--link' : ''}`}>{item.status}</span>
                </div>
                <h3 class="card__title">
                  {item.href ? (
                    <a href={item.href} target="_blank" rel="noopener">{item.title}</a>
                  ) : (
                    item.title
                  )}
                </h3>
                <p class="card__summary">{item.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</MarketingShell>

<style>
  @layer nbg.components {
    .card--planned {
      opacity: 0.6;
    }
  }
</style>
