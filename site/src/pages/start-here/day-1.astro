---
/**
 * /start-here/day-1 — AgentNews-aesthetic Day-1 onboarding journey.
 *
 * Preserves the existing markdown-segmentation + step-rendering logic
 * (Astro markdown processor, `## Step N — Title` split, server-side HTML
 * injection). Chrome is migrated to AgentNews .hero + .section + .wrap.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #10.
 * Backs AC10, AC15.
 */
import { getEntry } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import MarketingShell from '../../components/MarketingShell.astro';

const entry = await getEntry('journeys', 'day-1');
if (!entry) {
  throw new Error(
    "Missing journeys collection entry 'day-1' — expected at /journeys/day-1.md",
  );
}

const rawBody: string | undefined = entry.body;
if (typeof rawBody !== 'string' || rawBody.trim().length === 0) {
  throw new Error(
    "journeys/day-1.md has an empty body — expected `## Step N` segmented content.",
  );
}

interface ParsedStep {
  n: number;
  title: string;
  bodyMd: string;
}

function splitSteps(body: string): { intro: string; steps: ParsedStep[] } {
  const lines = body.split('\n');
  const headingRe = /^##\s+Step\s+(\d+)\s*[—\-]\s*(.+?)\s*$/;

  const introLines: string[] = [];
  const steps: ParsedStep[] = [];
  let current: ParsedStep | null = null;

  for (const line of lines) {
    const match = line.match(headingRe);
    if (match && match[1] && match[2]) {
      if (current) steps.push(current);
      current = { n: Number.parseInt(match[1], 10), title: match[2], bodyMd: '' };
      continue;
    }
    if (current) {
      current.bodyMd += (current.bodyMd ? '\n' : '') + line;
    } else {
      introLines.push(line);
    }
  }
  if (current) steps.push(current);

  for (const step of steps) {
    step.bodyMd = step.bodyMd.replace(/\n---\s*\n?\s*$/, '\n').trim();
  }

  return { intro: introLines.join('\n').trim(), steps };
}

const { intro, steps } = splitSteps(rawBody);

if (steps.length === 0) {
  throw new Error(
    "journeys/day-1.md contains no `## Step N` headings — Day-1 layout requires step segmentation.",
  );
}

const processor = await createMarkdownProcessor();

const renderedSteps = await Promise.all(
  steps.map(async (step) => {
    const result = await processor.render(step.bodyMd);
    return { ...step, html: result.code };
  }),
);

const introHtml = intro.length > 0 ? (await processor.render(intro)).code : '';

const heroTitle = entry.data.title ?? 'Day 1';
const heroSummary = entry.data.ai_summary;

const pullQuote = 'If you remember nothing else from today: Esc stops Claude.';
---

<MarketingShell
  title={heroTitle}
  description={heroSummary}
  surfaceId="day-1"
  width="full"
  hero="none"
>
  <section class="hero">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Day 1 — <em>what I wish I knew.</em></h1>
        <p class="hero__lede">
          {heroSummary}
          <small>Audience: {entry.data.audience} · ~30 min</small>
          <small><a href="/start-here/week-1/">→ Week 1 next</a></small>
        </p>
      </div>
    </div>
  </section>

  {introHtml.length > 0 && (
    <section class="section" id="intro" style="padding-block: 2rem;">
      <div class="wrap">
        <div class="journey-intro sl-markdown-content" set:html={introHtml} />
      </div>
    </section>
  )}

  {renderedSteps.map((step) => (
    <>
      <section
        class="section"
        id={`step-${step.n}`}
        data-step={step.n}
        aria-label={`Step ${step.n}: ${step.title}`}
      >
        <div class="wrap">
          <div class="section__head">
            <h2>Step {step.n} / {renderedSteps.length}</h2>
            <span class="count">{step.title}</span>
          </div>
          <div class="journey-step">
            <h3 class="journey-step__title">{step.title}</h3>
            <div class="journey-step__body sl-markdown-content" set:html={step.html} />
          </div>
        </div>
      </section>

      {step.n === 3 && (
        <section class="section section--pullquote" id="day-1-pullquote">
          <div class="wrap">
            <blockquote class="journey-pullquote">
              <p>{pullQuote}</p>
              <footer class="journey-pullquote__attrib">— what every newcomer learns in hour one</footer>
            </blockquote>
          </div>
        </section>
      )}
    </>
  ))}

  <section class="section" id="next">
    <div class="wrap">
      <div class="section__head">
        <h2>Tomorrow</h2>
        <span class="count">Three paths</span>
      </div>
      <div class="grid-3">
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta"><span class="eyebrow eyebrow--accent">Onboarding</span></div>
            <h3 class="card__title"><a href="/start-here/week-1/">Week 1 →</a></h3>
            <p class="card__summary">
              The week-1 journey is still drafting — but the planned topics
              are listed there so you know what's coming.
            </p>
          </div>
        </article>
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta"><span class="eyebrow eyebrow--accent">Skills</span></div>
            <h3 class="card__title"><a href="/skills/">Browse the catalog</a></h3>
            <p class="card__summary">
              Nine team-curated skills, each with a one-line install and a
              "what it actually does" summary.
            </p>
          </div>
        </article>
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta"><span class="eyebrow eyebrow--accent">Tips</span></div>
            <h3 class="card__title"><a href="/tips/">Tips &amp; tricks</a></h3>
            <p class="card__summary">
              Prompting patterns, survival keys, context discipline — the
              small habits that compound.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>
</MarketingShell>

<style>
  @layer nbg.components {
    .journey-intro {
      color: var(--nbg-ink-2);
      font-size: 1.125rem;
      line-height: 1.7;
      max-width: 56ch;
    }
    .journey-intro :global(p) {
      margin: 0 0 1rem 0;
    }
    .journey-step {
      max-width: 56rem;
      scroll-margin-top: 5rem;
    }
    .journey-step__title {
      font-family: var(--nbg-ff-serif);
      font-weight: 500;
      font-size: var(--nbg-fs-feature);
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--nbg-ink);
      margin: 0 0 1rem 0;
    }
    .journey-step__body {
      color: var(--nbg-ink);
      font-size: 1rem;
      line-height: 1.7;
    }
    .journey-step__body :global(p) {
      margin: 0 0 1rem 0;
    }
    .journey-step__body :global(p:last-child) {
      margin-bottom: 0;
    }
    .journey-step__body :global(ul),
    .journey-step__body :global(ol) {
      margin: 0 0 1rem 0;
      padding-left: 1.5rem;
    }
    .journey-step__body :global(li) {
      margin-bottom: 0.5rem;
    }
    .journey-step__body :global(code) {
      font-family: var(--nbg-ff-mono);
      font-size: 0.95em;
      background: var(--nbg-surface-2);
      padding: 0.1em 0.35em;
      border-radius: var(--nbg-r-sm);
    }
    .journey-step__body :global(pre) {
      background: var(--nbg-surface-2);
      border: 1px solid var(--nbg-hairline);
      border-radius: var(--nbg-r-md);
      padding: 1rem;
      overflow-x: auto;
    }
    .section--pullquote {
      background: var(--nbg-surface-2);
    }
    .journey-pullquote {
      font-family: var(--nbg-ff-serif);
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      line-height: 1.3;
      letter-spacing: -0.015em;
      color: var(--nbg-ink);
      margin: 0;
      max-width: 56rem;
      padding-left: 2rem;
      border-left: 3px solid var(--nbg-accent);
    }
    .journey-pullquote p {
      margin: 0 0 0.75rem 0;
      font-style: italic;
    }
    .journey-pullquote__attrib {
      font-family: var(--nbg-ff-mono);
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--nbg-muted);
      font-style: normal;
    }
  }
</style>
