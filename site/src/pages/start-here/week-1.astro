---
/**
 * /start-here/week-1 — AgentNews-aesthetic still-drafting surface.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #11.
 * Backs AC10, AC15.
 */
import MarketingShell from '../../components/MarketingShell.astro';

interface PlannedTopic {
  eyebrow: string;
  title: string;
  body: string;
  href: string;
  cta: string;
}

const plannedTopics: PlannedTopic[] = [
  { eyebrow: 'Foundations', title: 'Repo-wide CLAUDE.md',
    body: "Day 1 showed you the personal CLAUDE.md. Week 1 is when you co-author the project-level one — the rules everyone on the repo inherits.",
    href: '/glossary/#claudemd', cta: 'See the term →' },
  { eyebrow: 'Workflow', title: 'GSD workflows',
    body: "Get-Stuff-Done — the team's phase-based workflow. By the end of week 1 you should have driven a small change through plan → execute → verify.",
    href: '/glossary/#gsd', cta: 'What GSD is →' },
  { eyebrow: 'Shipping', title: 'Your first proper feature',
    body: "Stop using Claude for toy tasks. Pick something on the actual backlog — small but real — and let the workflow carry you.",
    href: '/skills/', cta: 'Skills that help →' },
  { eyebrow: 'Discipline', title: 'Reviewing AI output',
    body: "Trust nothing on first pass. By week's end you should know the three review traps every newcomer falls into (and the prompt that prevents them).",
    href: '/tips/', cta: 'Browse tips →' },
  { eyebrow: 'Reflexes', title: 'Survival keys, deeper',
    body: "Esc you already know. Esc Esc, /compact, /clear, screenshot Ctrl-V — internalise the muscle memory so you stop losing minutes to friction.",
    href: '/tips/', cta: 'Survival tips →' },
  { eyebrow: 'Community', title: 'Where to ask',
    body: "Every newcomer hits the same walls in their first week. Knowing which channel to ask in — and how to ask — saves hours.",
    href: '/contribute/', cta: 'How we contribute →' },
];
---

<MarketingShell
  title="Week 1"
  description="The week-1 onboarding journey is still drafting — here's what's coming and where to look in the meantime."
  surfaceId="week-1"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Week 1 — <em>still drafting.</em></h1>
        <p class="hero__lede">
          Day 1 ships you the keys. Week 1 turns the muscle memory into a
          real-feature delivery loop. We're still writing the full version —
          here's the outline, and where to look today.
          <small><a href="/start-here/day-1/">→ Day 1 first</a></small>
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="topics">
    <div class="wrap">
      <div class="section__head">
        <h2>What week 1 will cover</h2>
        <span class="count">{plannedTopics.length} topics</span>
      </div>
      <div class="grid-3">
        {plannedTopics.map((topic) => (
          <article class="card card--text">
            <div class="card__body">
              <div class="card__meta">
                <span class="eyebrow eyebrow--accent">{topic.eyebrow}</span>
              </div>
              <h3 class="card__title">{topic.title}</h3>
              <p class="card__summary">{topic.body}</p>
              <a class="feature__cta" href={topic.href}>{topic.cta}</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="cta">
    <div class="wrap">
      <div class="empty">
        <p class="empty__eyebrow">Today</p>
        <h2 class="empty__title">Start with Day 1 → first session.</h2>
        <p class="empty__body">
          Six steps, ~30 minutes. By the end you'll have run your first
          session, learned the survival keys, written CLAUDE.md, and
          browsed the skills marketplace. Week 1 picks up from there.
        </p>
        <div style="margin-top: 1.5rem;">
          <a class="feature__cta" href="/start-here/day-1/">Begin → Day 1</a>
        </div>
      </div>
    </div>
  </section>
</MarketingShell>
