---
/**
 * /news — AgentNews-aesthetic news feed.
 *
 * Composition: three named sections (AI-News, Deep Dives, Articles) driven
 * by render-time discriminator from lib/news-sections.ts. Feature picks the
 * most-recent Articles entry (or falls back through deep-dives → ai-news).
 *
 * Markup is raw AgentNews classes (.hero, .section, .wrap, .grid-3, .feature,
 * .card, .tag, .dates) consuming --nbg-* tokens.
 *
 * AudienceFilter + PinButton are preserved as-is — visual reskin only.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #2.
 * Backs AC10, AC11, AC12, AC13.
 */
import MarketingShell from '../../components/MarketingShell.astro';
import AudienceFilter from '../../components/AudienceFilter.astro';
import PinButton from '../../components/PinButton.astro';
import { getRecentNews } from '../../lib/news';
import {
  getNewsSection,
  groupNewsBySection,
  pickFeatureEntry,
  NEWS_SECTION_LABELS,
  NEWS_SECTION_TAGS,
  NEWS_SECTIONS,
} from '../../lib/news-sections';

const items   = await getRecentNews();
const grouped = groupNewsBySection(items);
const feature = pickFeatureEntry(items);

function formatDate(authored: string): string {
  return `${authored} UTC`;
}
---

<MarketingShell
  title="News"
  description="Curated Claude Code news from the RSS pipeline."
  surfaceId="news"
  width="full"
  hero="none"
>
  {/* ─── Hero ─────────────────────────────────────────────────────── */}
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">News from <em>the agent stack.</em></h1>
        <p class="hero__lede">
          Three streams: <strong>AI-News</strong> from Reddit discussion,
          <strong>Deep Dives</strong> from technical video walkthroughs, and
          <strong>Articles</strong> curated from around the web.
          <small>Updated {new Date().toISOString().slice(0, 10)} UTC</small>
          <small>Daily triage. No newsletter noise.</small>
        </p>
      </div>
      <div style="margin-top: 2rem;">
        <AudienceFilter scope=".card[data-audience]" />
      </div>
    </div>
  </section>

  {items.length === 0 ? (
    <section class="section">
      <div class="wrap">
        <div class="empty">
          <p class="empty__eyebrow">No items yet</p>
          <h2 class="empty__title">The feed is empty.</h2>
          <p class="empty__body">
            See <a href="/contribute/">Contribute</a> for how to add one, or
            wait for the daily RSS triage to land its first batch.
          </p>
        </div>
      </div>
    </section>
  ) : (
    <>
      {/* ─── Feature lead ──────────────────────────────────────────── */}
      {feature && (
        <section class="section" id="feature">
          <div class="wrap">
            <div class="section__head">
              <h2>Lead story</h2>
              <span class="count">{formatDate(feature.data.authored)}</span>
            </div>
            <article class="feature card" data-audience={feature.data.audience}>
              <a
                href={`/news/${feature.id}/`}
                class="feature__art feature__art--placeholder"
                aria-label={feature.data.title}
              >
                <span class="eyebrow eyebrow--accent">{NEWS_SECTION_TAGS[getNewsSection(feature)]}</span>
              </a>
              <div class="feature__body">
                <div class="feature__meta">
                  <span class="tag tag--link">{NEWS_SECTION_TAGS[getNewsSection(feature)]}</span>
                  <span class={`tag tag--audience-${feature.data.audience}`}>
                    {feature.data.audience}
                  </span>
                  <span class={`tag tag--confidence-${feature.data.editor_confidence}`}>
                    {feature.data.editor_confidence} confidence
                  </span>
                </div>
                <div class="dates">
                  <span class="date-item">
                    <span class="date-label">Published</span>
                    <span class="date-value">{formatDate(feature.data.authored)}</span>
                  </span>
                  {feature.data.source && (
                    <>
                      <span class="dot"></span>
                      <span class="date-item">
                        <span class="date-label">Source</span>
                        <span class="date-value">{feature.data.source}</span>
                      </span>
                    </>
                  )}
                </div>
                <h3 class="feature__title">
                  <a href={`/news/${feature.id}/`}>{feature.data.title}</a>
                </h3>
                {feature.data.ai_summary && (
                  <p class="feature__summary">{feature.data.ai_summary}</p>
                )}
                <div style="display: flex; align-items: center; gap: 1rem;">
                  <a class="feature__cta" href={`/news/${feature.id}/`}>
                    Read brief →
                  </a>
                  <PinButton type="news" slug={feature.id} />
                </div>
              </div>
            </article>
          </div>
        </section>
      )}

      {/* ─── Each named section ─────────────────────────────────────── */}
      {NEWS_SECTIONS.map((section) => {
        const sectionItems = grouped[section];
        // Skip the feature item from its bucket (it's already shown above)
        const visible = feature
          ? sectionItems.filter((e) => e.id !== feature.id)
          : sectionItems;
        if (visible.length === 0) return null;
        return (
          <section class="section" id={section}>
            <div class="wrap">
              <div class="section__head">
                <h2>{NEWS_SECTION_LABELS[section]}</h2>
                <span class="count">{visible.length} {visible.length === 1 ? 'item' : 'items'}</span>
              </div>
              <div class="grid-3">
                {visible.map((entry) => (
                  <article
                    class="card"
                    data-audience={entry.data.audience}
                    data-topics={entry.data.topics.join(',')}
                  >
                    <a
                      href={`/news/${entry.id}/`}
                      class="card__art card__art--placeholder"
                      aria-label={entry.data.title}
                    >
                      <span class="card__art__glyph">{NEWS_SECTION_TAGS[section]}</span>
                    </a>
                    <div class="card__body">
                      <div class="card__meta">
                        <span class="tag">{NEWS_SECTION_TAGS[section]}</span>
                        <span class={`tag tag--audience-${entry.data.audience}`}>
                          {entry.data.audience}
                        </span>
                      </div>
                      <div class="dates">
                        <span class="date-item">
                          <span class="date-label">Published</span>
                          <span class="date-value">{formatDate(entry.data.authored)}</span>
                        </span>
                      </div>
                      <h3 class="card__title">
                        <a href={`/news/${entry.id}/`}>{entry.data.title}</a>
                      </h3>
                      {entry.data.ai_summary && (
                        <p class="card__summary">{entry.data.ai_summary}</p>
                      )}
                      <div style="margin-top: 0.5rem;">
                        <PinButton type="news" slug={entry.id} />
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        );
      })}
    </>
  )}
</MarketingShell>

<style>
  @layer nbg.components {
    /* AudienceFilter hides cards via .audience-hidden class — preserve */
    .card.audience-hidden {
      display: none;
    }
  }
</style>
