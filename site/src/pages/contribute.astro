---
/**
 * /contribute — AgentNews-aesthetic two-path CTA.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #7.
 * Backs AC10, AC15.
 */
import MarketingShell from '../components/MarketingShell.astro';

interface FrontmatterKey {
  key: string;
  description: string;
}

const sharedKeys: FrontmatterKey[] = [
  { key: 'type', description: 'literal: news | skill | tip | glossary | journey-step' },
  { key: 'title', description: 'short, opinionated' },
  { key: 'audience', description: 'beginner | advanced | both' },
  { key: 'topics', description: 'array of strings, lowercase, kebab-case' },
  { key: 'internal', description: 'boolean, almost always false' },
  { key: 'authored', description: 'YYYY-MM-DD' },
  { key: 'last_reviewed', description: 'YYYY-MM-DD' },
  { key: 'external_link', description: 'URL or null' },
  { key: 'deeper_link', description: 'URL or null' },
  { key: 'ai_summary', description: '1-3 sentences' },
];
---

<MarketingShell
  title="Contribute"
  description="Two paths to ship a change to the hub — the form, or the pull request."
  surfaceId="contribute"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Two <em>paths in.</em></h1>
        <p class="hero__lede">
          The hub is a git repo. Everything you see lives as markdown under
          <code>news/</code>, <code>skills/</code>, <code>tips/</code>,
          <code>glossary/</code>, or <code>journeys/</code>. Pick a lane.
        </p>
      </div>
    </div>
  </section>

  <section class="section" id="paths">
    <div class="wrap">
      <div class="section__head">
        <h2>Pick a path</h2>
        <span class="count">2 ways</span>
      </div>
      <div class="feature">
        <div class="feature__art feature__art--placeholder">
          <span class="eyebrow eyebrow--accent">The fast path</span>
        </div>
        <div class="feature__body">
          <div class="feature__meta">
            <span class="tag tag--link">Web form</span>
          </div>
          <h3 class="feature__title">Submit a skill via the form.</h3>
          <p class="feature__summary">
            The submit-skill page is anonymous-accessible. Fill in the form,
            it validates against the 17-rule contract, and redirects you to
            GitHub's editor with the file pre-filled. Open the resulting PR
            from there — no local setup needed.
          </p>
          <div style="display:flex; gap:1rem; flex-wrap:wrap;">
            <a class="feature__cta" href="/submit-skill/">Open the form →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="pr-path">
    <div class="wrap">
      <div class="section__head">
        <h2>The PR path</h2>
        <span class="count">For anything else</span>
      </div>
      <div class="grid-2">
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta">
              <span class="tag">News · Tip · Glossary · Journey</span>
            </div>
            <h3 class="card__title">Fork → edit → PR.</h3>
            <p class="card__summary">
              For news items, tips, glossary terms, or onboarding journey
              edits, the simplest path is GitHub's web editor. Find the
              file, hit the pencil, write your change, and open a PR.
            </p>
            <a class="feature__cta" href="https://github.com/chomovazuzana/NbgAiHub" target="_blank" rel="noopener">
              Open the repo →
            </a>
          </div>
        </article>
        <article class="card card--text">
          <div class="card__body">
            <div class="card__meta">
              <span class="tag">Repo conventions</span>
            </div>
            <h3 class="card__title">Honour the conventions.</h3>
            <p class="card__summary">
              CLAUDE.md (root + global) covers naming, file layout,
              versioning. Take a minute before opening a PR — the bar is
              "opinionated, plainspoken, what I wish I knew a year ago."
            </p>
            <a class="feature__cta" href="https://github.com/chomovazuzana/NbgAiHub/blob/main/CLAUDE.md" target="_blank" rel="noopener">
              Read CLAUDE.md →
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="frontmatter">
    <div class="wrap">
      <div class="section__head">
        <h2>Shared frontmatter</h2>
        <span class="count">{sharedKeys.length} keys</span>
      </div>
      <div class="grid-3">
        {sharedKeys.map((key) => (
          <article class="card card--text">
            <div class="card__body">
              <div class="card__meta">
                <span class="tag" style="font-family: var(--nbg-ff-mono);">{key.key}</span>
              </div>
              <p class="card__summary">{key.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MarketingShell>
