---
/**
 * /contribute — Two-path CTA: submit-skill flow + GitHub PR flow.
 *
 * Composition: MarketingShell hero (Eyebrow + Display + Lede) + a Split
 * primitive putting the two paths side-by-side on desktop, stacking on mobile.
 * Below the split, a small editorial section about required frontmatter and
 * tone preserves the previous page's useful copy.
 *
 * Related: project-design.md §S.13.10.9, plan-004 §P4.F.
 * Backs: AC13.
 */
import MarketingShell from '../components/MarketingShell.astro';
import Section from '../components/primitives/Section.astro';
import Stack from '../components/primitives/Stack.astro';
import Cluster from '../components/primitives/Cluster.astro';
import Split from '../components/primitives/Split.astro';
import Card from '../components/primitives/Card.astro';
import Grid from '../components/primitives/Grid.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import Display from '../components/primitives/Display.astro';
import Lede from '../components/primitives/Lede.astro';
import Button from '../components/primitives/Button.astro';
import Kbd from '../components/primitives/Kbd.astro';
import Chip from '../components/primitives/Chip.astro';

interface FrontmatterKey {
  key: string;
  description: string;
}

const sharedKeys: FrontmatterKey[] = [
  { key: 'type', description: 'literal: news | skill | tip | glossary | journey-step' },
  { key: 'title', description: 'short, opinionated' },
  { key: 'audience', description: 'beginner | advanced | both' },
  { key: 'topics', description: 'array of strings, lowercase, kebab-case' },
  { key: 'internal', description: 'boolean, almost always false' },
  { key: 'authored', description: 'YYYY-MM-DD' },
  { key: 'last_reviewed', description: 'YYYY-MM-DD' },
  { key: 'external_link', description: 'URL or null' },
  { key: 'deeper_link', description: 'URL or null' },
  { key: 'ai_summary', description: '1-3 sentences' },
];
---

<MarketingShell
  title="Contribute"
  description="Two paths to ship a change to the hub — the form, or the pull request."
  surfaceId="contribute"
  width="wide"
>
  <Stack slot="hero" gap="6">
    <Eyebrow tone="accent">Contribute</Eyebrow>
    <Display level={1} size="lg">Two paths in.</Display>
    <Lede size="sm">
      The hub is a git repo. Everything you see lives as markdown under
      <code>news/</code>, <code>skills/</code>, <code>tips/</code>,
      <code>glossary/</code>, or <code>journeys/</code>. Pick a lane — the
      web form, or a direct PR.
    </Lede>
  </Stack>

  <Stack gap="12">
    <Section spacing="default" surfaceId="contribute-paths">
      <Split ratio="1/2" stack="md" gap="8">
        <div slot="start">
          <Card variant="feature">
            <Stack slot="header" gap="3">
              <Eyebrow tone="accent">The fast path</Eyebrow>
              <Display level={2} size="sm">Submit a skill via the form.</Display>
            </Stack>
            <Lede size="sm">
              Fill in the fields, watch the validator agree as you type, click
              submit, and you land on GitHub's editor with the file pre-filled.
              No fork required, no markdown required, no waiting.
            </Lede>
            <p class="contrib-meta">
              For: anyone, including newcomers. The validator runs the same
              17 rules our CI runs, so you'll never push a broken submission.
            </p>
            <Cluster slot="footer" gap="3" align="center">
              <Button variant="primary" size="lg" href="/submit-skill/">
                Open the form
              </Button>
              <a class="contrib-secondary" href="/skills/">Browse existing skills →</a>
            </Cluster>
          </Card>
        </div>
        <div slot="end">
          <Card variant="content">
            <Stack slot="header" gap="3">
              <Eyebrow>The deep path</Eyebrow>
              <Display level={2} size="sm">Open a pull request directly.</Display>
            </Stack>
            <Lede size="sm">
              For tips, glossary terms, journey edits, or anything more complex
              than a single skill. Fork, edit, PR.
            </Lede>
            <ol class="contrib-steps">
              <li>Fork or clone the repo.</li>
              <li>
                Drop a new markdown file in the appropriate folder. Frontmatter
                must satisfy the Zod schema — see existing entries for working
                examples.
              </li>
              <li>
                Run <code>cd site && npm run check</code> locally. If your
                frontmatter is wrong, this will tell you exactly which field
                on which file is off.
              </li>
              <li>Open a PR. Keep it small. One topic per PR.</li>
            </ol>
            <Cluster slot="footer" gap="3" align="center">
              <Cluster gap="1" align="center">
                <Kbd>gh</Kbd>
                <Kbd>pr</Kbd>
                <Kbd>create</Kbd>
              </Cluster>
              <Button
                variant="secondary"
                size="md"
                href="https://github.com/chomovazuzana/NbgAiHub"
                target="_blank"
                rel="noopener"
              >
                Open repo on GitHub ↗
              </Button>
            </Cluster>
          </Card>
        </div>
      </Split>
    </Section>

    <Section spacing="default" surfaceId="contribute-frontmatter" tone="subtle">
      <Stack gap="6">
        <Stack gap="3">
          <Eyebrow tone="accent">Frontmatter contract</Eyebrow>
          <Display level={2} size="sm">The 10 keys every content file needs.</Display>
          <Lede size="sm">
            News adds three more — <code>editor_confidence</code>,
            <code>source</code>, and <code>fingerprint</code> — but the AI
            triage pipeline fills those in for you.
          </Lede>
        </Stack>
        <Grid columns="auto-fit" min="22rem" gap="3">
          {sharedKeys.map((item) => (
            <Card variant="content">
              <Stack slot="header" gap="2">
                <Cluster gap="2" align="center">
                  <Chip><code>{item.key}</code></Chip>
                </Cluster>
              </Stack>
              <p class="contrib-key-desc">{item.description}</p>
            </Card>
          ))}
        </Grid>
      </Stack>
    </Section>

    <Section spacing="snug" surfaceId="contribute-tone">
      <Stack gap="3">
        <Eyebrow tone="accent">Tone</Eyebrow>
        <Display level={2} size="sm">"What I wish I knew a year ago."</Display>
        <Lede size="sm">
          Opinionated. Plainspoken. No marketing voice. No AI-slop hedging.
          Assume the reader is a smart colleague new to Claude Code.
        </Lede>
      </Stack>
    </Section>
  </Stack>
</MarketingShell>

<style>
  @layer nbg.components {
    .contrib-meta {
      margin: 0;
      color: var(--nbg-color-fg-muted);
      font-size: var(--nbg-fs-sm);
      line-height: var(--nbg-lh-base);
    }
    .contrib-secondary {
      font-family: var(--nbg-type-mono);
      font-size: var(--nbg-fs-sm);
      color: var(--nbg-color-link);
      text-decoration: none;
    }
    .contrib-secondary:hover {
      text-decoration: underline;
    }
    .contrib-steps {
      margin: 0;
      padding-left: var(--nbg-sp-5);
      color: var(--nbg-color-fg-secondary);
      font-size: var(--nbg-fs-md);
      line-height: var(--nbg-lh-relaxed);
    }
    .contrib-steps li + li {
      margin-top: var(--nbg-sp-2);
    }
    .contrib-key-desc {
      margin: 0;
      color: var(--nbg-color-fg-secondary);
      font-size: var(--nbg-fs-sm);
      line-height: var(--nbg-lh-base);
    }
  }
</style>
