---
/**
 * /skills — AgentNews-aesthetic skills catalog.
 *
 * Single AgentNews section with grid-3 of skill cards. Lead skill shown as
 * a .feature. AudienceFilter + PinButton preserved.
 *
 * Related: project-design.md §S.13.16, plan-005 phase 4 #3.
 * Backs AC10, AC11, AC15.
 */
import { getCollection } from 'astro:content';
import MarketingShell from '../components/MarketingShell.astro';
import AudienceFilter from '../components/AudienceFilter.astro';
import PinButton from '../components/PinButton.astro';

const items = await getCollection('skills');
const sorted = items.sort((a, b) => {
  const byDate = b.data.authored.localeCompare(a.data.authored);
  return byDate !== 0 ? byDate : a.data.title.localeCompare(b.data.title);
});
const lead = sorted[0];
const rest = sorted.slice(1);
---

<MarketingShell
  title="Skills"
  description="The skills catalog — reusable Claude Code skills and plugins worth your attention."
  surfaceId="skills"
  width="full"
  hero="none"
>
  <section class="hero hero--compact">
    <div class="wrap">
      <div class="hero__intro">
        <h1 class="hero__title">Skills worth <em>installing.</em></h1>
        <p class="hero__lede">
          A curated catalog of Claude Code skills and plugins — the ones we
          keep reaching for. Each entry tells you what the skill does,
          who it's for, and how to install it.
          <small>{items.length} entries</small>
        </p>
      </div>
      <div style="margin-top: 2rem;">
        <AudienceFilter scope=".card[data-audience]" />
      </div>
    </div>
  </section>

  {lead && (
    <section class="section">
      <div class="wrap">
        <div class="section__head">
          <h2>Featured skill</h2>
          <span class="count">{lead.data.origin}</span>
        </div>
        <article class="feature card" data-audience={lead.data.audience}>
          <div class="feature__art feature__art--placeholder">
            <span class="eyebrow eyebrow--accent">/{lead.data.skill_id}</span>
          </div>
          <div class="feature__body">
            <div class="feature__meta">
              <span class="tag tag--link">{lead.data.category}</span>
              <span class={`tag tag--audience-${lead.data.audience}`}>{lead.data.audience}</span>
              <span class="tag">{lead.data.origin}</span>
            </div>
            <h3 class="feature__title">{lead.data.title}</h3>
            <p class="feature__summary">{lead.data.ai_summary}</p>
            <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
              {lead.data.external_link && (
                <a class="feature__cta" href={lead.data.external_link} target="_blank" rel="noopener">
                  View source →
                </a>
              )}
              <PinButton type="skill" slug={lead.id} />
            </div>
          </div>
        </article>
      </div>
    </section>
  )}

  {rest.length > 0 && (
    <section class="section">
      <div class="wrap">
        <div class="section__head">
          <h2>All skills</h2>
          <span class="count">{rest.length} more</span>
        </div>
        <div class="grid-3">
          {rest.map((entry) => (
            <article class="card card--text" data-audience={entry.data.audience}>
              <div class="card__body">
                <div class="card__meta">
                  <span class="tag tag--link">/{entry.data.skill_id}</span>
                  <span class={`tag tag--audience-${entry.data.audience}`}>{entry.data.audience}</span>
                </div>
                <h3 class="card__title">{entry.data.title}</h3>
                <p class="card__summary">{entry.data.ai_summary}</p>
                <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 0.5rem;">
                  {entry.data.external_link && (
                    <a class="external-host" href={entry.data.external_link} target="_blank" rel="noopener">
                      <span>{entry.data.origin}</span>
                    </a>
                  )}
                  <PinButton type="skill" slug={entry.id} />
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</MarketingShell>

<style>
  @layer nbg.components {
    .card.audience-hidden { display: none; }
  }
</style>
